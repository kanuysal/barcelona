---
import Preloader from "../components/common/Preloader.astro";
import Header from "../components/common/Header.astro";
import MobileMenu from "../components/common/MobileMenu.astro";
import Footer from "../components/common/Footer.astro";
import CookieBanner from "../components/common/CookieBanner.astro";

interface Props {
  title: string;
  description?: string;
  swupRoute?: string;
  navRoute?: string;
  showFooter?: boolean;
  hideFilter?: boolean;
}

import { getLangFromUrl } from "../i18n/utils";

interface Props {
  title: string;
  description?: string;
  swupRoute?: string;
  navRoute?: string;
  showFooter?: boolean;
  hideFilter?: boolean;
}

const { 
  title, 
  description = "Mina Lidya Elite Couture", 
  swupRoute = "home",
  navRoute,
  showFooter = true,
  hideFilter = false
} = Astro.props;

const lang = getLangFromUrl(Astro.url);

// Determine which nav item should be highlighted. If navRoute is strictly provided, use it. Otherwise use swupRoute.
const currentNavRoute = navRoute || swupRoute;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=5" />
    <meta name="description" content={description} />
    <link rel="icon" href="data:," />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" href="/fonts/ppneuemontreal-book.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/ppneuemontreal-medium.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Noto+Sans+JP:wght@400;500&display=swap">

    <title>{title}</title>

    <!-- Site Styles -->
    <link rel="stylesheet" href="/_astro/about.DH1rYjoT.css">

    <!-- Authoritative Head Libraries (Core 3D) -->
    <script is:inline src="/assets/js/three.min.js"></script>
    <script is:inline src="/assets/js/astro-components.js"></script>

    <slot name="head" />

    <script is:inline>
      (function() {
        const supportedLangs = ['tr', 'en', 'es'];
        const defaultLang = 'tr';
        const storageKey = 'mina-preferred-lang';
        
        // 1. Get current path language
        const pathParts = window.location.pathname.split('/').filter(Boolean);
        const currentPathLang = supportedLangs.includes(pathParts[0]) ? pathParts[0] : defaultLang;
        
        // 2. Check storage or navigator
        let preferredLang = localStorage.getItem(storageKey);
        if (!preferredLang) {
          const browserLang = navigator.language.split('-')[0];
          preferredLang = supportedLangs.includes(browserLang) ? browserLang : defaultLang;
        }

        // 3. Update storage if we are on a specific language path
        if (pathParts[0] && supportedLangs.includes(pathParts[0])) {
          localStorage.setItem(storageKey, pathParts[0]);
        }

        // 4. Redirect ONLY on first visit to root /
        if (window.location.pathname === '/' && preferredLang !== defaultLang && !sessionStorage.getItem('mina-redirected')) {
          sessionStorage.setItem('mina-redirected', 'true');
          window.location.href = '/' + preferredLang + '/';
        }
      })();
    </script>
  </head>
  <body class="body">
    <!-- Custom Preloader -->
    <Preloader />

    <Header currentNav={currentNavRoute} lang={lang} />
    <MobileMenu />

    <div id="swup" class="container" data-swup-route={swupRoute}>
      <slot />
      {showFooter && <Footer lang={lang} />}
    </div>

    <!-- Cookie Banner -->
    <CookieBanner />

    {!hideFilter && (
      <>
        <div class="c-transition-filter"></div>
        <div class="c-mouse" aria-hidden="true">
          <div class="c-mouse__ball"></div>
        </div>
      </>
    )}

    <!-- Site engine (deferred module) - Provides global gsap/ScrollTrigger -->
    <script type="module" src="/assets/js/layout-engine.js" defer></script>
    
    <slot name="scripts" />
  </body>
</html>
