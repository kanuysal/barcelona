---
import MainLayout from '../layouts/MainLayout.astro';
import LookbookGrid from '../components/lookbook/LookbookGrid';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<MainLayout 
  title="Lookbook | Mina Lidya - Elite Couture"
  hideFilter={true}
>
  <section class="lookbook-section" data-lenis="main">
    <LookbookGrid client:only="react" lang={lang} />
  </section>
</MainLayout>

<style>
  .lookbook-section {
    width: 100%;
    height: 100vh;
    background: #fff;
    position: relative;
  }

  /* Force hide transition filter on this page to avoid double overlay */
  :global(.c-transition-filter) {
    pointer-events: none !important;
    display: none !important;
  }
</style>

<script>
  // Disable smooth scroll for this page if needed, as R3F has its own rig
  document.addEventListener('astro:page-load', () => {
    if (window.location.pathname.includes('lookbook')) {
        // Force a resize event to wake up R3F
        window.dispatchEvent(new Event('resize'));
    }
  });
</script>
