---
import MainLayout from "../layouts/MainLayout.astro";
import Footer from "../components/common/Footer.astro";

const updates = [
  {
    date: "2026-03-27",
    title: "Mina Lidya Elite Couture Web Sitemiz Yayınlandı.",
    body: "Lüksün ve zerafetin yeni adresi Mina Lidya olarak, dijital dünyada sizlere kapılarımızı açtık.",
    image: "/assets/images/gelinlik.webp",
    link: null
  },
  {
    date: "2026-02-09",
    title: "Veronica Elite Koleksiyonu Tanıtıldı.",
    body: "Evrensel zarafeti Anadolu ruhunla harmanlayan Veronica Elite koleksiyonumuz görücüye çıktı.",
    image: "/assets/images/Veronica Elite (1).webp",
    link: null
  },
  {
    date: "2026-01-15",
    title: "İnegöl Atölyemiz Kapılarını Açtı.",
    body: "Tarihi tekstil şehri İnegöl'deki üretim atölyemiz, en kaliteli kumaşlarla haute couture üretimine başladı.",
    image: "/assets/images/abiye.webp",
    link: null
  }
];

const selectedWorks = [
  {
    href: "/category",
    image: "/assets/images/Veronica Elite (1).webp",
    number: "Selected 01",
    title: "Veronica Elite Gelinlik",
    role: "Elite Couture"
  },
  {
    href: "/category",
    image: "/assets/images/abiye.webp",
    number: "Selected 02",
    title: "Dantel Detaylı Abiye",
    role: "Abiye Serisi"
  },
  {
    href: "/category",
    image: "/assets/images/curvy.webp",
    number: "Selected 03",
    title: "Büyük Beden Koleksiyonu",
    role: "Özel Tasarım"
  },
  {
    href: "/category",
    image: "/assets/images/gelinlik.webp",
    number: "Selected 04",
    title: "Klasik Gelinlik",
    role: "Gelinlik Serisi"
  }
];
---

<MainLayout
  title="Atölye | Mina Lidya - Elite Couture"
  description="Mina Lidya Elite Couture & Bridal Studio - En Yeni Koleksiyonlar ve Atölye Çalışmaları."
  swupRoute="index"
>
  <main class="main" data-lenis="main">
    <div class="index">

      <!-- Hero / MV Section -->
      <section class="index-mv">
        <div class="index-mv__head">
          <h1 class="index-mv__head-title c-head-font" data-text="split">
            Zerafet ve <br>Kusursuz İşçilik
          </h1>
        </div>

        <div class="index-mv__video-time">
          <p class="c-en-text--sm" data-text="split">0:00</p>
        </div>

        <div class="index-mv__under">
          <div class="index-mv__mode">
            <button class="index-mv__mode-button">
              <span class="c-en-text--md" data-text="split">+ Focus Mode</span>
            </button>
          </div>
        </div>

        <div class="index-mv__filter"></div>
        <div class="index-mv__main-filter"></div>
        <div class="index-background">
          <div id="index-webgl"></div>
          <div class="index-background__video-filter"></div>
          <video src="/assets/videos/haute.mp4" muted loop playsinline preload="auto" autoplay></video>
        </div>

        <div class="index-mv__focus">
          <div class="information c-en-text--md" data-grid="1">
            <p class="title"><span data-focus="text">MINA LIDYA</span></p>
            <p><span data-focus="text">Elite Haute Couture</span></p>
            <p><span data-focus="text">İnegöl Atölye</span></p>
            <p><span data-focus="text">Valencia Stüdyo</span></p>
            <p><span data-focus="text">Est. 2026</span></p>
          </div>
          <div class="catchcopy c-head-font">
            <p>
              <span data-focus="text">
                <span class="catchcopy-sub">Bespoke</span> Elegance
              </span>
            </p>
          </div>
          <div class="information c-en-text--md" data-grid="2">
            <p class="title"><span data-focus="text">SERVİSLER</span></p>
            <p><span data-focus="text">Özel Dikim Gelinlik</span></p>
            <p><span data-focus="text">Haute Couture Abiye</span></p>
            <p><span data-focus="text">Stil Danışmanlığı</span></p>
            <p><span data-focus="text">Kaftan Tasarımı</span></p>
          </div>
        </div>
      </section>

      <!-- About section -->
      <section class="index-about">
        <div class="index-about__inner" data-split="container">
          <h2 class="index-about__title c-head-font">
            Tasarımlarımız, Avrupalı gelinlik butikleri tarafından çok beğeniliyor.
          </h2>
          <div class="index-about__card">
            <article class="index-about__card-body">
              <div class="index-about__card-bring"></div>
              <p class="index-about__card-gps">40.0820° N, 29.5090° E | 38.7073° N, 0.4764° W</p>
              <p class="c-head-font"><span>Based in</span> <br>İnegöl / BURSA & Alcoy / SPAIN</p>
              <p class="c-head-font"><span>Est. '26</span></p>
            </article>
            <div class="index-about__card-background">
              <img src="/assets/images/abiye.webp" alt="Mina Lidya Atölye">
            </div>
          </div>
          <div class="index-about__group">
            <h3 class="index-about__sub c-en-text--sm u-book">(Stüdyo Hakkında)</h3>
            <p class="index-about__text-ja c-ja-text u-justify">
              Bursa merkezli butik bir haute couture stüdyosuyuz.<br class="u-pc">
              Her dikişte zerafeti ve kusursuz işçiliği hedefleyerek<br class="u-pc">
              size özel tasarımlar hayata geçiriyoruz.
            </p>
            <p class="index-about__text-en c-en-text--sm">
              A boutique haute couture studio based in Bursa, bringing elegance to life with impeccable craftsmanship.
            </p>
            <div class="index-about__link">
              <a href="/about-us" class="c-en-text--sm" data-hover="line">
                <span class="line">Hakkımızda Daha Fazlası</span>
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Service section -->
      <section class="index-service">
        <div class="index-service__inner" data-split="container">
          <h2 class="index-service__title c-head-font">
            <span data-split="inner">
              <span data-split="target">Hizmetlerimiz</span>
            </span>
          </h2>
          <div class="index-service__contents c-en-text--xl">
            <p>Özel Dikim Gelinlik</p>
            <p>Haute Couture Abiye</p>
            <p>Kına & Kaftan Tasarımı</p>
            <p>Kişiye Özel Stil Danışmanlığı</p>
          </div>
          <div class="index-service__texts">
            <p class="c-ja-text">Hayallerinizdeki haute couture deneyimini, usta ellerde şekillenen <br class="u-pc">kumaşlarla sanata dönüştürüyoruz. <br class="u-sp">Her detayda kalite ve zerafeti hissedeceksiniz.</p>
            <p class="c-en-text--sm">We transform your dream haute couture experience into art <br>with fabrics shaped by master hands.</p>
          </div>
        </div>
      </section>

      <!-- Selected works / Case section -->
      <section class="index-case" data-split="container">
        <div class="index-case__title">
          <h2 class="index-case__title-main c-head-font">
            <span data-split="inner">
              <span data-split="target">Seçilmiş Tasarımlar</span>
            </span>
          </h2>
        </div>
        <div class="index-case__contents">
          {selectedWorks.map((item, i) => (
            <a href={item.href} class="index-case__item" data-grid={i} data-target="case" data-hover="line">
              <div class="index-case__item-image">
                <div class="image-wrapper">
                  <div class="image-inner">
                    <img src={item.image} alt={item.title} fetchpriority={i === 0 ? "high" : "auto"} loading={i === 0 ? "eager" : "lazy"}>
                  </div>
                </div>
                <p class="index-case__item-number c-en-text--sm">{item.number}</p>
              </div>
              <div class="index-case__item-detail">
                <h3 class="title c-en-text--sm">
                  <span class="line">{item.title}</span>
                </h3>
                <p class="role c-en-text--sm u-book">{item.role}</p>
              </div>
            </a>
          ))}
        </div>
        <div class="index-case__link">
          <a href="/category" class="c-en-text--sm" data-hover="line">
            <span class="line">Tüm Kategorileri Gör</span>
          </a>
        </div>
      </section>

      <!-- Approach section -->
      <section class="approach" data-split="container">
        <h2 class="approach__title c-head-font">
          <span data-split="inner">
            <span data-split="target">Yaklaşımımız</span>
          </span>
        </h2>
        <p class="approach__ja c-ja-text">Zerafet, kalite ve mükemmelliği her dikişte birleştiriyoruz.</p>
        <p class="approach__en c-en-text--sm u-book">We combine elegance, quality and perfection in every stitch.</p>
        <div class="approach__tags">
          <p class="tag c-en-text--sm u-book">Seamless</p>
          <p class="tag c-en-text--sm u-book">Functional</p>
          <p class="tag c-en-text--sm u-book">Smooth</p>
        </div>
        <div class="approach__background">
          <div class="approach__background-inner">
            <video class="approach__video" muted loop playsinline preload="metadata" src="/assets/videos/featured-video.mp4"></video>
          </div>
        </div>
      </section>

      <!-- Updates section -->
      <section class="c-updates" data-split="container">
        <div class="c-updates__inner">
          <div class="c-updates__head">
            <h2 class="c-updates__head-title c-head-font">
              <span data-split="inner">
                <span data-split="target">Atölyeden Günceler</span>
              </span>
            </h2>
          </div>
          <div class="c-updates__contents">
            <ul class="c-updates__items">
              {updates.map((item) => (
                <li class="c-updates__item">
                  <div class="thumbnail">
                    <img src={item.image} alt={item.title} width="290" height="180" loading="lazy" />
                  </div>
                  <div class="contents">
                    <time datetime={item.date} class="day u-book">{item.date}</time>
                    <h2 class="title c-en-text--md">{item.title}</h2>
                    <div class="contents-body c-en-text--sm">
                      <p>{item.body}</p>
                    </div>
                    {item.link && (
                      <a href={item.link} class="c-en-text--sm related" target="_blank" data-hover="line">
                        <span class="line">İlgili Bağlantı</span>
                      </a>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <!-- Lab section -->
      <section class="c-lab" data-split="container" data-color="white">
        <div class="c-lab__inner">
          <div class="c-lab__cover">
            <h2 class="c-lab__title c-en-text--sm u-book">(Atölye)</h2>
            <p class="c-lab__ja c-ja-text">
              İnce işçilik ve yaratıcılıkla<br>şekillenen tasarımlarımızı keşfedin.
            </p>
            <p class="c-lab__en c-en-text--sm u-book">
              Explore our designs shaped with fine craftsmanship and creativity.
            </p>
            <div class="c-lab__link">
              <a href="/showcase" class="c-en-text--sm" data-hover="line" data-animation="sticky-text">
                <span class="line">Koleksiyona Göz At</span>
              </a>
            </div>
          </div>
          <div class="c-lab__background">
            <div class="c-lab__background-video">
              <video src="/assets/videos/heroml.mp4" autoplay muted loop playsinline></video>
            </div>
          </div>
        </div>
      </section>

      <!-- Readme section -->
      <section class="c-readme-section" data-split="container" data-color="black">
        <div class="c-readme-section__inner">
          <h2 class="c-readme-section__title c-head-font">
            <span data-split="inner">
              <span data-split="target">
                Nasıl Çalışıyoruz?
              </span>
            </span>
          </h2>
          <p class="c-ja-text">
            Süreçlerimiz ve Haute Couture yaklaşımımız hakkında <br class="u-sp">detaylı bilgi almak için hazırladığımız kılavuzu inceleyin.
          </p>
          <div class="c-readme-section__link">
            <a href="/about-us" class="c-en-text--sm" data-hover="line">
              <span class="line">Hakkımızda</span>
            </a>
          </div>
        </div>
      </section>

    </div>
  </main>

  <style is:global>
    /* Force dark background — layout-engine may lag setting body color */
    .index-about__card {
      background: rgba(255, 255, 255, 0.2) !important;
      backdrop-filter: blur(10px) !important;
      -webkit-backdrop-filter: blur(10px) !important;
      border: 1px solid rgba(255, 255, 255, 0.1) !important;
    }

    .index-mv {
      background: #050505;
      position: relative;
      overflow: hidden;
      min-height: 100svh;
    }

    .index-background {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .index-background video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .index-mv__head {
      position: absolute !important;
      top: auto !important;
      bottom: 15vh !important;
      left: 4vw !important;
      z-index: 10 !important;
      margin: 0 !important;
    }

    .index-mv__under {
      position: absolute !important;
      top: auto !important;
      bottom: 8vh !important;
      left: 4vw !important;
      z-index: 11 !important;
      margin: 0 !important;
    }

    .index-mv__video-time {
      position: absolute !important;
      top: auto !important;
      bottom: 8vh !important;
      right: 4vw !important;
      z-index: 10 !important;
    }

    body.body {
      background: #050505 !important;
    }
  </style>
</MainLayout>
