import ML_AboutHero from "../components/sections/ML_AboutHero.astro";
---

<MainLayout title="Hakkımızda | Mina Lidya - Elite Couture" swupRoute="about">
  <link slot="head" rel="preload" as="image" href="/assets/images/yaren.webp" media="(max-width: 767px)" crossorigin="anonymous">
  <link slot="head" rel="preload" as="image" href="/assets/images/yaren.webp" media="(min-width: 768px)" crossorigin="anonymous">

  <main class="main" data-lenis="main">
    <div class="about">
      <ML_AboutHero 
        title="Mina Lidya Elite" 
        subtext="Anadolu Mirası ve Akdeniz Tutkusuyla Harmanlanan Bilimsel Güzellik Yaklaşımı."
        eliteTitle="Mina Lidya Studio"
        bgImage="/assets/images/yaren.webp"
      />

      
      <section class="about-thought">
        <div class="about-thought__image">
          <div class="about-thought__image-inner">
            <picture>
              <source srcset="/assets/images/abiye.webp" media="(max-width:767px)">
              <img src="/assets/images/abiye.webp" alt="Mina Lidya Couture" loading="eager" fetchpriority="high">
            </picture>
          </div>
        </div>
      </section>

      <section class="about-what-do" data-split="container">
        <div class="about-what-do__inner">
          <h2 class="about-what-do__title c-head-font">
            Servisler & Hizmetler
          </h2>
          <div class="about-what-do__contents">
            <div class="about-what-do__contents-items">
              <div class="about-what-do__contents-item">
                <h3 class="main-title c-en-text--lg">Biz Mimarlarız</h3>
                <h4 class="hedding c-en-text--sm u-book">(Güzelliğin Bilimi)</h4>
                <div class="group">
                  <p class="text c-ja-text u-justify-pc">
                    Doktoralı tekstil mühendisleri, vizyoner stilistler ve usta tasarımcılardan oluşan bir koalisyon tarafından kurulan Mina Lidya, sadece bir marka değil, güzelliğe bilimsel bir yaklaşımdır.
                  </p>
                  <p class="en-text c-en-text--sm u-book">
                    Founded by a coalition of PhD-holding textile engineers and visionary stylists, it is a scientific approach to beauty.
                  </p>
                </div>
              </div>
              <div class="about-what-do__contents-item" data-margin="true">
                <h3 class="main-title c-en-text--lg">İnegöl Atölye</h3>
                <h4 class="hedding c-en-text--sm u-book">(Üretimin Merkezi)</h4>
                <div class="group">
                  <p class="text c-ja-text u-justify-pc">
                    Tarihi tekstil başkentimiz İnegöl, Bursa'da köklenen üretim atölyemiz, geleneğin teknolojiyle buluştuğu yerdir. En kaliteli kumaşları kendi tesislerimizde işliyoruz.
                  </p>
                  <p class="en-text c-en-text--sm u-book">
                    Our production atelier in Inegol, Bursa, is where world-renowned tradition meets technology.
                  </p>
                </div>
              </div>
              <div class="about-what-do__contents-item">
                <h3 class="main-title c-en-text--lg">Valencia Stüdyo</h3>
                <h4 class="hedding c-en-text--sm u-book">(Global Tasarım)</h4>
                <div class="group">
                  <p class="text c-ja-text u-justify-pc">
                    İspanya'nın kalbinde filizlenen tasarım ofisimiz ve küresel satış yönetimimizle, Anadolu mirası ile Avrupa haute couture'ü arasında köprü kuruyoruz.
                  </p>
                  <p class="en-text c-en-text--sm u-book">
                    With our design office in the heart of Spain, we bridge the gap between Anatolian heritage and European haute couture.
                  </p>
                </div>
              </div>
              <div class="about-what-do__contents-item">
                <h3 class="main-title c-en-text--lg">Saf Kalite</h3>
                <h4 class="hedding c-en-text--sm u-book">(En İyi Tedarik)</h4>
                <div class="group">
                  <p class="text c-ja-text u-justify-pc">
                    Vizyonumuzu kaliteden ödün vermeden sürdürmek için Avrupa'nın önde gelen tesisleriyle işbirliği yapıyoruz. Dantel ve kumaşlarımız doğrudan en iyi fabrikalardan temin edilmektedir.
                  </p>
                  <p class="en-text c-en-text--sm u-book">
                    Our lace and fabrics are sourced directly from the finest factories in Europe to ensure uncompromised quality.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <div class="about-background">
        <div class="about-origin" data-split="container">
          <div class="about-origin__head">
            <h2 class="about-origin__title c-head-font">
              Mina Lidya Hizmet Standartları
            </h2>
          </div>
          <div class="about-origin__details" data-split="container">
            <h3 class="title c-en-text--sm u-book">(Origin)</h3>
            <p class="text-ja c-ja-text">
              Perspektif, Yapı, İfade ve Değer. Biz Mina Lidya'yız. Anadolu mirasının Akdeniz tutkusuyla harmanlanmasından doğan markamızla, sadece elbise değil, miraslar yaratıyoruz.
            </p>
          </div>
        </div>

        <section class="about-axes">
          <div id="webgl"></div>
          <div class="about-axes__inner">
            <div class="about-axes__contents">
              <div class="about-axes__item" data-grid="1">
                <h2 class="about-axes__item-title c-head-font"><span>01.</span>Özel Tasarım</h2>
                <p class="c-ja-text">Kişiye özel haute couture tasarımlarımızla<br>hayallerinizi gerçeğe dönüştürüyoruz.</p>
              </div>

              <div class="about-axes__item" data-grid="2">
                <h2 class="about-axes__item-title c-head-font"><span>02.</span>Stilistik Danışmanlığı</h2>
                <p class="c-ja-text">
                  Sizin için en uygun stil ve kesimin belirlenmesi için<br>uzman danışmanlık hizmeti sunuyoruz.
                </p>
              </div>

              <div class="about-axes__item" data-grid="3">
                <h2 class="about-axes__item-title c-head-font"><span>03.</span>Gelin Makyaj Stüdyosu</h2>
                <p class="c-ja-text">En özel gününüzde profesyonel makyaj hizmetimizle<br>zerafetinizi tamamlıyoruz.</p>
              </div>

              <div class="about-axes__item" data-grid="4">
                <h2 class="about-axes__item-title c-head-font"><span>04.</span>Kına Organizasyonu</h2>
                <p class="c-ja-text">Unutulmaz kına geceleri için<br>eksiksiz ve masalsı organizasyonlar yapıyoruz.</p>
              </div>
            </div>
          </div>
          <div class="about-axes__block"></div>
        </section>

        <section class="about-photo">
          <div class="about-photo__main-image">
            <div class="inner">
              <video src="/assets/videos/hero-lookbook.mp4" autoplay muted loop playsinline style="width: 100%; height: 100%; object-fit: cover;"></video>
            </div>
          </div>
        </section>

        <section class="about-contact">
          <div class="about-contact__group" data-split="container">
            <h2 class="about-contact__title c-en-text--sm u-book">(İletişim)</h2>
            <p class="about-contact__ja c-ja-text">
              Size özel tasarımlar ve sorularınız için<br class="u-sp"> bizimle her zaman iletişime geçebilirsiniz.
            </p>
            <p class="about-contact__en c-en-text--sm u-book">
              Zerafete giden yolda ilk adımı atın.
            </p>
            <a href="mailto:store@minalidya.com" class="c-head-font" data-hover="line">
              <span data-split="inner">
                <span data-split="target">
                  <span class="line">store@minalidya.com</span>
                </span>
              </span>
            </a>
          </div>
        </section>

        <section class="c-lab" data-split="container" data-color="black">
          <div class="c-lab__inner">
            <div class="c-lab__cover">
              <h2 class="c-lab__title c-en-text--sm u-book">(Sanatsal Atölye)</h2>
              <p class="c-lab__ja c-ja-text">
                Kumaşın sanatla buluştuğu,<br>her detayın tutkuyla işlendiği bir dünya.
              </p>
              <p class="c-lab__en c-en-text--sm u-book">
                Modayı bir tuval olarak görüyor, tasarımlarımızda sanatsal bir derinlik arıyoruz.
              </p>
              <div class="c-lab__link">
                <a href="/lab/" class="c-en-text--sm" data-hover="line" data-animation="sticky-text">
                  <span class="line">Atölyeyi Keşfedin</span>
                </a>
              </div>
            </div>
            <div class="c-lab__background">
              <div class="c-lab__background-video">
                <video src="/assets/videos/heroml.mp4" autoplay muted loop playsinline></video>
              </div>
            </div>
          </div>
        </section>

        <section class="c-readme-section" data-split="container" data-color="white">
          <div class="c-readme-section__inner">
            <h2 class="c-readme-section__title c-head-font">
              <span data-split="inner">
                <span data-split="target">
                  Dikiş Sanatımız
                </span>
              </span>
            </h2>
            <p class="c-ja-text">Tasarımdan son provaya kadar, haute couture yolculuğunun her adımını<br class="u-sp"> büyük bir titizlikle planlıyoruz.</p>
            <div class="c-readme-section__link">
              <a href="/guide/" class="c-en-text--sm" data-hover="line">
                <span class="line">Süreci Keşfedin</span>
              </a>
            </div>
          </div>
        </section>
      </div>
    </main>
</MainLayout>
