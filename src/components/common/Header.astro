---
const { currentNav = "" } = Astro.props;
---
<header class="header">
  <div class="header__inner">
    <a href="/" class="header__logo" aria-label="Mina Lidya Ana Sayfa">
      <span class="c-logo">
        <span>M</span>
        <span>İ</span>
        <span>N</span>
        <span>A</span>
        <span style="margin-left: 0.3em;">L</span>
        <span>İ</span>
        <span>D</span>
        <span>Y</span>
        <span>A</span>
      </span>
    </a>
    <nav class="header__nav">
      <ul class="header__ul">
        <li class="header__li" data-list="about">
          <a href="/about-us/" data-nav="about" class={currentNav === "about" ? "is-current" : ""} data-hover="line" style={currentNav === "about" ? "pointer-events: none;" : ""}><p class="line">Hakkımızda</p></a>
        </li>
        <li class="header__li" data-list="showcase">
          <a href="/showcase/" data-nav="showcase" data-hover="line"><p class="line">Koleksiyon</p></a>
        </li>
        <li class="header__li" data-list="lookbook">
          <a href="/lookbook/" data-nav="lookbook" data-hover="line" data-no-swup><p class="line">Lookbook</p></a>
        </li>
        <li class="header__li" data-list="case">
          <a href="https://hikaye.minalidya.wedding/" target="_blank" rel="noopener noreferrer" data-nav="case" data-hover="line"><p class="line">Story</p></a>
        </li>
        <li class="header__li" data-list="updates">
          <a href="/atelier" data-nav="updates" data-hover="line"><p class="line">Atölye</p></a>
        </li>
      </ul>
    </nav>
    <div class="header__contact" data-list="contact">
      <a href="/contact" data-nav="contact" data-hover="line"><p class="line">İletişim</p></a>
    </div>
  </div>
</header>

<style>
  .header {
    mix-blend-mode: difference;
    z-index: 1000;
  }
  .c-logo span {
    color: #fff; /* Difference will make it black on white background */
  }
  .header__nav a, .header__contact a {
    color: #fff;
  }
</style>
