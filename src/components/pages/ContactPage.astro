---
import MainLayout from "../../layouts/MainLayout.astro";
import { useTranslations, getRelativeLocaleUrl } from "../../i18n/utils";

const { lang = "tr" } = Astro.props;
const t = useTranslations(lang);
import Footer from "../../components/common/Footer.astro";
---

<MainLayout 
  title="İletişim | Mina Lidya - Elite Couture" 
  description="Hayalinizdeki gelinlik ve gece kıyafetleri için Mina Lidya ile iletişime geçin. Randevu alın."
  swupRoute="contact"
>
  <main class="main" data-lenis="main">
    <script is:inline>
      window.__MV_IMAGE = "/assets/images/yaren.webp";
      document.addEventListener('astro:page-load', () => {
        const aboutNav = document.querySelector('li[data-list="about"] a');
        if(aboutNav) aboutNav.classList.remove('is-current');
      });
    </script>
    <div class="about">
      <div class="about-sticky">
        <section class="about-message">
          <div class="about-message__text">
            <p class="about-message__text-main c-head-font">
              <span>{t('contact.rendezvous')}</span>
            </p>
            <p class="about-message__text-sub c-ja-text">
              <span>{t('contact.rendezvous.text')}</span>
            </p>
          </div>
          <div id="about-mv-webgl"></div>
        </section>
        <section class="about-mv">
          <div class="about-mv__contents">
            <h1 class="about-mv__contents-title c-head-font" data-target="split">{t('contact.title')}</h1>
            <div class="about-mv__contents-time">
              <div class="about-mv__contents-bring"></div>
              <p class="about-mv__contents-current c-en-text--sm">
                <span data-current="time" data-target="split"></span>
                <span data-target="split">/</span>
                <span data-current="type" data-target="split"></span>
              </p>
            </div>
          </div>
        </section>
        <div class="about-sticky__block"></div>
      </div>
      
      <section class="about-thought">
        <div class="about-thought__image">
          <div class="about-thought__image-inner">
            <picture>
              <source srcset="/assets/images/wide%20%2821%29.webp" media="(max-width:767px)">
              <img src="/assets/images/wide%20%2821%29.webp" alt="Mina Lidya Randevu" loading="eager" fetchpriority="high">
            </picture>
          </div>
        </div>
      </section>

      <section class="about-what-do" data-split="container">
        <div class="about-what-do__inner">
          <h2 class="about-what-do__title c-head-font">
            {t('contact.locations')}
          </h2>
          <div class="about-what-do__contents">
            <div class="about-what-do__contents-items">
              <div class="about-what-do__contents-item">
                <h3 class="main-title c-en-text--lg">Türkiye</h3>
                <h4 class="hedding c-en-text--sm u-book">{t('contact.center')}</h4>
                <div class="group">
                  <p class="text c-ja-text u-justify-pc">
                    Bursa / İnegöl<br>
                    Kasım Efendi Caddesi No.25A<br>
                    <br>
                    <a href="https://wa.me/905421131641" target="_blank" style="text-decoration: underline;">+90 542 113 16 41</a><br>
                    <a href="mailto:store@minalidya.com" style="text-decoration: underline;">store@minalidya.com</a>
                  </p>
                  <p class="en-text c-en-text--sm u-book">
                    Our production atelier in Inegol, Bursa, is where world-renowned tradition meets technology.
                  </p>
                </div>
              </div>
              <div class="about-what-do__contents-item" data-margin="true">
                <h3 class="main-title c-en-text--lg">İspanya</h3>
                <h4 class="hedding c-en-text--sm u-book">{t('contact.sales')}</h4>
                <div class="group">
                  <p class="text c-ja-text u-justify-pc">
                    Alcoy / Alicante<br>
                    Mina Lidya Novias<br>
                    <br>
                    <a href="https://wa.me/34632623300" target="_blank" style="text-decoration: underline;">+34 632 623 300</a><br>
                    <a href="mailto:novias@minalidya.es" style="text-decoration: underline;">novias@minalidya.es</a>
                  </p>
                  <p class="en-text c-en-text--sm u-book">
                    With our design office in the heart of Spain, we bridge the gap between Anatolian heritage and European haute couture.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <div class="about-background">
        <div class="about-origin" data-split="container">
          <div class="about-origin__head">
            <h2 class="about-origin__title c-head-font">
              {t('contact.design')}
            </h2>
          </div>
          <div class="about-origin__details" data-split="container">
            <h3 class="title c-en-text--sm u-book">{t('contact.support')}</h3>
            <p class="text-ja c-ja-text">
              {t('contact.support.text')}
            </p>
          </div>
        </div>

        <section class="about-axes">
          <div id="webgl"></div>
          <div class="about-axes__inner">
            <div class="about-axes__contents">
              <div class="about-axes__item" data-grid="1">
                <h2 class="about-axes__item-title c-head-font"><span>01.</span>{t('contact.service.1.title')}</h2>
                <p class="c-ja-text">{t('contact.service.1.text')}</p>
              </div>

              <div class="about-axes__item" data-grid="2">
                <h2 class="about-axes__item-title c-head-font"><span>02.</span>{t('contact.service.2.title')}</h2>
                <p class="c-ja-text">
                  {t('contact.service.2.text')}
                </p>
              </div>

              <div class="about-axes__item" data-grid="3">
                <h2 class="about-axes__item-title c-head-font"><span>03.</span>{t('contact.service.3.title')}</h2>
                <p class="c-ja-text">{t('contact.service.3.text')}</p>
              </div>

              <div class="about-axes__item" data-grid="4">
                <h2 class="about-axes__item-title c-head-font"><span>04.</span>{t('contact.service.4.title')}</h2>
                <p class="c-ja-text">{t('contact.service.4.text')}</p>
              </div>
            </div>
          </div>
          <div class="about-axes__block"></div>
        </section>

        <section class="about-photo">
          <div class="about-photo__main-image">
            <div class="inner">
              <video src="/assets/videos/hero-lookbook.mp4" autoplay muted loop playsinline style="width: 100%; height: 100%; object-fit: cover;"></video>
            </div>
          </div>
        </section>

        <section class="about-contact">
          <div class="about-contact__group" data-split="container">
            <h2 class="about-contact__title c-en-text--sm u-book">{t('contact.email')}</h2>
            <p class="about-contact__ja c-ja-text">
              {t('contact.email.text')}
            </p>
            <p class="about-contact__en c-en-text--sm u-book">
              {t('contact.email.sub')}
            </p>
            <a href="mailto:store@minalidya.com" class="c-head-font" data-hover="line">
              <span data-split="inner">
                <span data-split="target">
                  <span class="line">store@minalidya.com</span>
                </span>
              </span>
            </a>
          </div>
        </section>

        <section class="c-readme-section" data-split="container" data-color="white">
          <div class="c-readme-section__inner">
            <h2 class="c-readme-section__title c-head-font">
              <span data-split="inner">
                <span data-split="target">
                  {t('contact.explore')}
                </span>
              </span>
            </h2>
            <p class="c-ja-text">{t('contact.explore.text')}</p>
            <div class="c-readme-section__link">
              <a href={getRelativeLocaleUrl(lang, "/showcase/")} class="c-en-text--sm" data-hover="line">
                <span class="line">Showcase</span>
              </a>
            </div>
          </div>
        </section>
      </div>
    </main>
</MainLayout>
