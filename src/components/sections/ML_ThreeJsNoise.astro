---
// ML_ThreeJsNoise.astro - 1:1 Original Implementation from ThreeJsNoise-main
---
<div class="ml-three-noise-container">
  <div id="ml-three-noise-render"></div>
  <div class="ml-noise-overlay">
    <h2>SIMPLEX NOISE FIELD</h2>
    <p>Vertex & Fragment Katmanlı Hibrit Noise Deformasyonu</p>
  </div>
</div>

<style>
  .ml-three-noise-container {
    position: relative;
    width: 100%;
    height: 700px;
    background: #111;
    overflow: hidden;
  }

  #ml-three-noise-render {
    width: 100%;
    height: 100%;
  }

  .ml-noise-overlay {
    position: absolute;
    bottom: 40px;
    left: 40px;
    color: white;
    pointer-events: none;
    z-index: 10;
  }

  .ml-noise-overlay h2 {
    font-family: 'Cinzel', serif;
    font-size: 1.5rem;
    letter-spacing: 0.3em;
    margin-bottom: 5px;
  }

  .ml-noise-overlay p {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    opacity: 0.6;
  }
</style>

<script>
  import * as THREE from 'three';
  import { gsap } from 'gsap';

  class MLThreeJsNoise {
    constructor(el) {
      this.container = el;
      this.renderTarget = el.querySelector("#ml-three-noise-render");
      this.width = el.clientWidth;
      this.height = el.clientHeight;
      this.isRendering = false;
      this.retryCount = 0;
      
      this.init();
    }

    init() {
      // Handled by Toggle Buttons in elements3
      this.setupScene();
    }

    setupScene() {
      if (this.retryCount > 10) return;

      try {
        this.scene = new THREE.Scene();
        this.camera = new THREE.PerspectiveCamera(60, this.width / this.height, 0.1, 200);
        this.camera.position.z = 8;

        this.renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        if (!this.renderer.getContext()) throw new Error("Context Failed");

        this.renderer.setClearColor(0x111111, 1);
        this.renderer.setSize(this.width, this.height);
        this.renderTarget.appendChild(this.renderer.domElement);

        const noiseFunctions = `
          vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
          vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
          vec3 permute(vec3 x) { return mod289(((x*34.0)+10.0)*x); }
          float snoise(vec2 v) {
            const vec4 C = vec4(0.211324865405187, 0.366025403784439, -0.577350269189626, 0.024390243902439);
            vec2 i = floor(v + dot(v, C.yy));
            vec2 x0 = v - i + dot(i, C.xx);
            vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
            vec4 x12 = x0.xyxy + C.xxzz;
            x12.xy -= i1;
            i = mod289(i);
            vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0)) + i.x + vec3(0.0, i1.x, 1.0));
            vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy), dot(x12.zw,x12.zw)), 0.0);
            m = m*m; m = m*m;
            vec3 x = 2.0 * fract(p * C.www) - 1.0;
            vec3 h = abs(x) - 0.5;
            vec3 ox = floor(x + 0.5);
            vec3 a0 = x - ox;
            m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
            vec3 g;
            g.x = a0.x * x0.x + h.x * x0.y;
            g.yz = a0.yz * x12.xz + h.yz * x12.yw;
            return 80.0 * dot(m, g);
          }
        `;

        this.geometry = new THREE.PlaneGeometry(8, 10, 50, 80);
        this.material = new THREE.ShaderMaterial({
          uniforms: {
            uTime: { value: 0.0 },
            uVertexTime: { value: 0.1 },
          },
          vertexShader: `
            varying vec2 vUv;
            uniform float uVertexTime;
            ${noiseFunctions}
            void main() {
              vUv = uv;
              vec3 pos = position;
              pos.x += snoise(pos.xy) * uVertexTime;
              pos.y += snoise(normalize(pos.xy)) * uVertexTime;
              gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
            }
          `,
          fragmentShader: `
            varying vec2 vUv;
            uniform float uTime;
            ${noiseFunctions}
            void main() {
              float offset = snoise(vUv + uTime * 0.1);
              gl_FragColor = vec4(vec3(offset * 0.5 + 0.5), 1.0);
            }
          `
        });

        this.mesh = new THREE.Mesh(this.geometry, this.material);
        this.scene.add(this.mesh);

        this.tl = gsap.to(this.material.uniforms.uVertexTime, {
          value: 1.2,
          ease: "Power2.easeInOut",
          repeat: -1,
          yoyo: true,
          duration: 4,
        });

        this.isRendering = true;
        this.animate();
        window.addEventListener("resize", () => this.onResize());
      } catch (e) {
        console.warn("ThreeJsNoise WebGL busy, retrying in 1s...", e);
        this.retryCount++;
        setTimeout(() => this.setupScene(), 1000);
      }
    }

    dispose() {
      this.isRendering = false;
      if (this.tl) this.tl.kill();
      if (!this.renderer) return;
      const extension = this.renderer.getContext().getExtension('WEBGL_lose_context');
      if (extension) extension.loseContext();
      this.renderer.dispose();
      this.renderer.domElement.remove();
      this.renderer = null;
      this.scene = null;
      this.camera = null;
    }

    onResize() {
      if (!this.renderer) return;
      this.width = this.container.clientWidth;
      this.height = this.container.clientHeight;
      this.renderer.setSize(this.width, this.height);
      this.camera.aspect = this.width / this.height;
      this.camera.updateProjectionMatrix();
    }

    animate() {
      if (!this.isRendering) return;
      requestAnimationFrame(() => this.animate());
      this.material.uniforms.uTime.value += 0.05;
      if (this.renderer && this.scene && this.camera) {
        this.renderer.render(this.scene, this.camera);
      }
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    const el = document.querySelector(".ml-three-noise-container");
    if (!el) return;
    
    let instance = null;
    window.addEventListener('ml-init-23', () => {
      try {
        if (!instance) instance = new MLThreeJsNoise(el);
      } catch (err) {
        el.innerHTML = `<div style="color:#ff4444; padding:20px; font-family:monospace; font-size:12px;">Three.js Error: ${err.message}</div>`;
      }
    });

    window.addEventListener('ml-dispose-23', () => {
      if (instance) {
        instance.dispose();
        instance = null;
      }
    });
  });
</script>
