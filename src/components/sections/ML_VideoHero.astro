---
// src/components/sections/ML_VideoHero.astro
interface Props {
  title?: string;
  videoSrc?: string;
}
const { 
  title = "Zarafet ile Tasarlandı",
  videoSrc = "/assets/videos/hero-lookbook.mp4"
} = Astro.props;
---


<section class="ml-mv index-mv">


  <!-- Bottom-left: Main title (chars animate in) -->
  <div class="ml-mv__head index-mv__head">



    <h1 class="ml-mv__head-title c-head-font" aria-label={title}>
      <span class="words" set:html={title} />
    </h1>

  </div>

  <!-- Centre bottom: Video time -->
  <div class="ml-mv__video-time index-mv__video-time">



    <p class="c-en-text--sm">0:00</p>
  </div>

  <!-- Bottom-right: Focus Mode toggle -->
  <div class="ml-mv__under index-mv__under">



    <div class="ml-mv__mode">
      <button class="ml-mv__mode-button" id="focusModeBtn">
        <span class="c-en-text--md">+ Focus Mode</span>
      </button>
    </div>
  </div>

  <!-- Overlay layers -->
  <div class="ml-mv__filter index-mv__filter"></div>
  <div class="ml-mv__main-filter index-mv__main-filter"></div>




  <!-- Background: Native video (no WebGL — GPU budget goes to HeroSlider) -->
  <div class="ml-background index-background">




    <video id="mlHeroVideo" muted loop playsinline preload="auto">
      <source src={videoSrc} type="video/mp4" />
    </video>

    <!-- CSS overlay for darkening (replaces Three.js u_dark uniform) -->
    <div class="ml-background__overlay"></div>
  </div>

  <!-- Focus Mode info panel -->
  <div class="ml-mv__focus index-mv__focus">





    <div class="information c-en-text--md" data-grid="1">
      <p class="info-title"><span data-focus="text">Mina Lidya</span></p>
      <p><span data-focus="text">Modern Tasarımlar</span></p>
      <p><span data-focus="text">Haute Couture</span></p>
      <p><span data-focus="text">Kişiselleştirilebilir</span></p>
      <p><span data-focus="text">Özgün Tasarımlar</span></p>
    </div>

    <div class="catchcopy c-head-font">
      <p>
        <span data-focus="text">
          <span class="catchcopy-sub">Her an</span> kusursuz
        </span>
      </p>
    </div>

    <div class="information c-en-text--md" data-grid="2">
      <p class="info-title"><span data-focus="text">Koleksiyonlar</span></p>
      <p><span data-focus="text">Gelinlik Modası</span></p>
      <p><span data-focus="text">Modern Tesettür</span></p>
      <p><span data-focus="text">Kına Kıyafetleri</span></p>
      <p><span data-focus="text">İthal Abiyeler</span></p>
    </div>

  </div>

</section>

<style>
  /* ─── SECTION ────────────────────────────────────────── */
  .ml-mv {
    width: 100%;
    height: 100svh;
    position: relative;
    overflow: hidden;
    background: #050505;
    isolation: isolate;
  }

  /* ─── CHARS ANIMATION ────────────────────────────────── */
  .ml-mv .words {
    display: inline-block;
    height: fit-content;
    overflow: hidden;
  }

  .ml-mv .chars {
    display: inline-block;
    transform: translate3d(0, 100%, 0);
    will-change: transform;
  }

  /* ─── BOTTOM-LEFT TITLE ──────────────────────────────── */
  .ml-mv__head {
    position: absolute;
    bottom: 26px;
    left: 32px;
    z-index: 2;
  }

  .ml-mv__head-title {
    color: #f0f0f0;
    line-height: 0.9;
  }

  .ml-mv__head-title .words:nth-of-type(1),
  .ml-mv__head-title .words:nth-of-type(2) {
    opacity: 0.55;
  }

  .ml-mv__head-title .chars {
    font-size: 9vw;
  }

  @media (max-width: 767px) {
    .ml-mv__head-title .chars { font-size: 12vw; }
    .ml-mv__head { left: 20px; }
  }

  /* ─── VIDEO TIME ─────────────────────────────────────── */
  .ml-mv__video-time {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translate(-50%);
    z-index: 2;
    pointer-events: none;
  }

  .ml-mv__video-time p {
    color: rgba(240,240,240,0.7);
    font-size: 11px;
    letter-spacing: 0.1em;
    font-family: monospace;
  }

  @media (max-width: 767px) {
    .ml-mv__video-time { bottom: auto; top: 22px; }
  }

  /* ─── BOTTOM-RIGHT MODE BUTTON ───────────────────────── */
  .ml-mv__under {
    position: absolute;
    right: 32px;
    bottom: 30px;
    z-index: 2;
  }

  .ml-mv__mode-button {
    color: #f0f0f0;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-size: 13px;
    letter-spacing: 0.05em;
    opacity: 0.8;
    transition: opacity 0.3s;
    position: relative;
  }
  .ml-mv__mode-button:hover { opacity: 1; }

  .ml-mv__mode-button::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0%;
    height: 1px;
    background: #f0f0f0;
    transition: width 0.4s ease;
  }
  .ml-mv__mode-button:hover::after { width: 100%; }

  /* ─── FILTER LAYERS ──────────────────────────────────── */
  .ml-mv__filter {
    position: absolute;
    inset: 0;
    background: #000;
    opacity: 0;
    z-index: 3;
    pointer-events: none;
  }

  .ml-mv__main-filter {
    position: absolute;
    inset: 0;
    background: #000;
    opacity: 1;
    z-index: 1;
    pointer-events: none;
  }

  /* ─── BACKGROUND ─────────────────────────────────────── */
  .ml-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100svh;
    will-change: transform;
  }

  /* Native video — fullscreen cover, browser hardware-decodes */
  .ml-background video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    display: block;
  }

  /* CSS darkening overlay (replaces Three.js shader) */
  .ml-background__overlay {
    position: absolute;
    inset: 0;
    background: #000;
    opacity: 0.15;
    pointer-events: none;
    z-index: 1;
  }

  /* ─── FOCUS MODE PANEL ───────────────────────────────── */
  .ml-mv__focus {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: 20px;
    padding-inline: 40px;
    z-index: 2;
    pointer-events: none;
    align-items: center;
  }

  .ml-mv__focus .information {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ml-mv__focus .information[data-grid="1"] { grid-column: 1 / span 4; }
  .ml-mv__focus .information[data-grid="2"] { grid-column: 9 / span 4; text-align: right; }

  @media (max-width: 767px) {
    .ml-mv__focus { padding-inline: 20px; column-gap: 10px; }
    .ml-mv__focus .information[data-grid="1"] { grid-column: 1 / span 6; }
    .ml-mv__focus .information[data-grid="2"] { grid-row: 2; grid-column: 7 / span 6; }
  }

  .ml-mv__focus .information p {
    color: rgba(240, 240, 240, 0.55);
    overflow: hidden;
    height: fit-content;
    font-size: 13px;
    letter-spacing: 0.03em;
    line-height: 1.5;
  }

  .ml-mv__focus .information .info-title {
    color: #f0f0f0;
    opacity: 1;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .ml-mv__focus [data-focus="text"] {
    display: inline-block;
    transform: translate3d(0, 100%, 0);
    will-change: transform;
  }

  /* Centre catchcopy */
  .ml-mv__focus .catchcopy {
    grid-column: 1 / -1;
    grid-row: 1;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    text-align: center;
    pointer-events: none;
  }

  .ml-mv__focus .catchcopy p {
    font-size: clamp(28px, 4vw, 52px);
    color: #f0f0f0;
    overflow: hidden;
    line-height: 1.1;
    height: fit-content;
  }

  .ml-mv__focus .catchcopy [data-focus="text"] {
    display: inline-block;
    transform: translate3d(0, 100%, 0);
    will-change: transform;
  }

  .ml-mv__focus .catchcopy .catchcopy-sub {
    color: rgba(240, 240, 240, 0.5);
  }
</style>

<script is:inline>
  (function initMLVideoHero() {
    console.log('DIAG: ML_VideoHero init start');
    const section = document.querySelector('.ml-mv');
    if (!section) return;
    
    // Check if scripts are loaded
    const checkGlobals = setInterval(() => {
        if (window.ML_VideoHero && window.gsap && window.ScrollTrigger) {
            clearInterval(checkGlobals);
            // Register ScrollTrigger one more time for safety
            window.gsap.registerPlugin(window.ScrollTrigger);
            
            if (!window._videoHeroInstance) {
                const isMobile = window.innerWidth <= 767;
                window._videoHeroInstance = new window.ML_VideoHero({ isMobile });
            }
        }
    }, 100);

  })();
</script>
