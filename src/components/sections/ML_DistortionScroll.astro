---
// ML_DistortionScroll.astro - 1:1 Original Implementation from distortionScroll-main
const { 
  img1 = "wide (20).webp", 
  img2 = "wide (21).webp", 
  img3 = "wide (23).webp",
  noise = "noise.webp"
} = Astro.props;
---
<div class="ml-distortion-scroll-wrapper" data-img1={img1} data-img2={img2} data-img3={img3} data-noise={noise}>
  <!-- We create multiple sections to provide scroll triggers within the library context -->
  <div class="ml-scroll-track" id="ml-track-25">
    <div id="sec01" class="ml-trigger-section"></div>
    <div id="sec02" class="ml-trigger-section"></div>
    <div id="sec03" class="ml-trigger-section"></div>
    
    <div class="ml-sticky-render">
      <div id="ml-distortion-render"></div>
    </div>

    <div class="ml-distortion-overlay">
      <h2>DISTORTION SCROLL</h2>
      <p>Scroll Hızına Duyarlı WebGL Geçiş Algoritması</p>
    </div>
  </div>
</div>

<style>
  .ml-distortion-scroll-wrapper {
    position: relative;
    width: 100%;
    background: #000;
  }

  .ml-scroll-track {
    position: relative;
    height: 300vh; /* 3 screens of scroll for a 10-module page might be too much, but let's stick to the concept */
  }

  .ml-trigger-section {
    height: 100vh;
    width: 100%;
    pointer-events: none;
  }

  .ml-sticky-render {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: 1;
  }

  #ml-distortion-render {
    width: 100%;
    height: 100%;
  }

  .ml-distortion-overlay {
    position: fixed;
    bottom: 40px;
    right: 40px;
    text-align: right;
    color: white;
    pointer-events: none;
    z-index: 10;
    mix-blend-mode: difference;
  }

  .ml-distortion-overlay h2 {
    font-family: 'Cinzel', serif;
    font-size: 1.5rem;
    letter-spacing: 0.3em;
  }
</style>

<script>
  import * as THREE from 'three';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  class MLDistortionScroll {
    constructor(el) {
      this.container = el;
      this.renderTarget = el.querySelector("#ml-distortion-render");
      
      const d = el.dataset;
      this.textures = {
        t1: `/assets/images/${d.img1 || 'wide (20).webp'}`,
        t2: `/assets/images/${d.img2 || 'wide (21).webp'}`,
        t3: `/assets/images/${d.img3 || 'wide (23).webp'}`,
        noise: `/assets/images/${d.noise || 'noise.webp'}`
      };
      
      this.width = window.innerWidth;
      this.height = window.innerHeight;
      this.isRendering = false;
      this.retryCount = 0;

      this.init();
    }

    init() {
      // Handled by external toggle
      this.setupScene();
    }

    async setupScene() {
      if (this.retryCount > 10) return;

      try {
        this.scene = new THREE.Scene();
        this.camera = new THREE.PerspectiveCamera(60, this.width / this.height, 0.1, 100);
        this.camera.position.z = 1.5;

        this.renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        if (!this.renderer.getContext()) throw new Error("Context Failed");

        this.renderer.setSize(this.width, this.height);
        this.renderTarget.appendChild(this.renderer.domElement);

        const loader = new THREE.TextureLoader();
        const [t1, t2, t3, n] = await Promise.all([
          loader.loadAsync(this.textures.t1),
          loader.loadAsync(this.textures.t2),
          loader.loadAsync(this.textures.t3),
          loader.loadAsync(this.textures.noise)
        ]);

        this.material = new THREE.ShaderMaterial({
          uniforms: {
            uResolution: { value: new THREE.Vector2(this.width, this.height) },
            uImageResolution: { value: new THREE.Vector2(2048, 1356) },
            uTexture: { value: t1 },
            uNextTexture: { value: t2 },
            uFinalTexture: { value: t3 },
            disp: { value: n },
            uChangeTransition: { value: 0.0 },
            uChangeTransition02: { value: 0.0 },
            uTime: { value: 0.0 }
          },
          vertexShader: `
            varying vec2 vUv;
            void main() {
              vUv = uv;
              gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
            }
          `,
          fragmentShader: `
            uniform vec2 uResolution;
            uniform vec2 uImageResolution;
            uniform float uChangeTransition;
            uniform float uChangeTransition02;
            uniform float uTime;
            uniform sampler2D uTexture;
            uniform sampler2D uNextTexture;
            uniform sampler2D uFinalTexture;
            uniform sampler2D disp;
            varying vec2 vUv;

            void main() {
              vec2 ratio = vec2(
                min((uResolution.x / uResolution.y) / (uImageResolution.x / uImageResolution.y), 1.0),
                min((uResolution.y / uResolution.x) / (uImageResolution.y / uImageResolution.x), 1.0)
              );
              vec2 uv = vUv * ratio + (1.0 - ratio) * 0.5;

              vec4 n = texture2D(disp, uv);
              float dist = distance(uv, n.xy) + clamp(n.x, n.y, vUv.y) * sin(uTime * 10.0);

              vec2 changeVec = vec2(0.0, -1.0);
              float intensity = 0.7;

              vec2 pos1 = uv + (dist * intensity * uChangeTransition) * changeVec;
              vec2 pos2 = uv + (dist * -(intensity * (3.0 - (3.0 * uChangeTransition)))) * changeVec;
              vec2 pos3 = uv + (dist * -(intensity * (3.0 - (3.0 * uChangeTransition02)))) * changeVec;

              vec4 c1 = texture2D(uTexture, pos1);
              vec4 c2 = texture2D(uNextTexture, pos2);
              vec4 c3 = texture2D(uFinalTexture, pos3);

              vec4 mix1 = mix(c1, c2, uChangeTransition);
              gl_FragColor = mix(mix1, c3, uChangeTransition02);
            }
          `
        });

        this.mesh = new THREE.Mesh(new THREE.PlaneGeometry(2, 2, 100, 100), this.material);
        this.scene.add(this.mesh);

        // STanimations using ScrollTrigger
        gsap.to(this.material.uniforms.uChangeTransition, {
          value: 1,
          scrollTrigger: {
            trigger: "#sec01",
            start: "top top",
            end: "bottom top",
            scrub: true,
          }
        });

        gsap.to(this.material.uniforms.uChangeTransition02, {
          value: 1,
          scrollTrigger: {
            trigger: "#sec02",
            start: "top top",
            end: "bottom top",
            scrub: true,
          }
        });

        this.isRendering = true;
        this.animate();
        window.addEventListener("resize", () => this.onResize());
      } catch (e) {
        console.warn("DistortionScroll WebGL busy, retrying...", e);
        this.retryCount++;
        setTimeout(() => this.setupScene(), 1000);
      }
    }

    dispose() {
      this.isRendering = false;
      ScrollTrigger.getAll().forEach(t => {
        if (t.vars.trigger === "#sec01" || t.vars.trigger === "#sec02") t.kill();
      });
      if (!this.renderer) return;
      const extension = this.renderer.getContext().getExtension('WEBGL_lose_context');
      if (extension) extension.loseContext();
      this.renderer.dispose();
      this.renderer.domElement.remove();
      this.renderer = null;
      this.scene = null;
      this.camera = null;
    }

    onResize() {
      if (!this.renderer) return;
      this.width = window.innerWidth;
      this.height = window.innerHeight;
      this.renderer.setSize(this.width, this.height);
      this.material.uniforms.uResolution.value.set(this.width, this.height);
      this.camera.aspect = this.width / this.height;
      this.camera.updateProjectionMatrix();
    }

    animate() {
      if (!this.isRendering) return;
      requestAnimationFrame(() => this.animate());
      this.material.uniforms.uTime.value += 0.01;
      if (this.renderer && this.scene && this.camera) {
        this.renderer.render(this.scene, this.camera);
      }
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    const el = document.querySelector(".ml-distortion-scroll-wrapper");
    if (!el) return;
    
    let instance = null;
    window.addEventListener('ml-init-25', () => {
      try {
        if (!instance) instance = new MLDistortionScroll(el);
      } catch (err) {
        el.innerHTML = `<div style="color:#ff4444; padding:20px; font-family:monospace; font-size:12px;">Three.js Error: ${err.message}</div>`;
      }
    });

    window.addEventListener('ml-dispose-25', () => {
      if (instance) {
        instance.dispose();
        instance = null;
      }
    });
  });
</script>
