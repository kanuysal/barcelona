---
// ML_CityModel.astro - 1:1 Original Implementation from City-Three-Model-main
const { modelUrl = "/assets/images/city.glb" } = Astro.props;
---
<div class="ml-city-container" data-model={modelUrl}>
  <div id="ml-city-render"></div>
  <div class="ml-city-overlay">
    <h2>CITY THREE MODEL</h2>
    <p>3D Şehir Yapılandırması & Toon Shader Işıklandırma</p>
  </div>
</div>

<style>
  .ml-city-container {
    position: relative;
    width: 100%;
    height: 800px;
    background: #91d0f3; /* Original sky blue background */
    overflow: hidden;
  }

  #ml-city-render {
    width: 100%;
    height: 100%;
  }

  .ml-city-overlay {
    position: absolute;
    top: 40px;
    left: 40px;
    color: #111;
    pointer-events: none;
    z-index: 10;
  }

  .ml-city-overlay h2 {
    font-family: 'Cinzel', serif;
    font-size: 1.5rem;
    letter-spacing: 0.3em;
    margin-bottom: 5px;
  }

  .ml-city-overlay p {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    opacity: 0.7;
  }
</style>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';
  import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';

  class MLCityModel {
    constructor(el) {
      this.container = el;
      this.renderTarget = el.querySelector("#ml-city-render");
      this.modelUrl = el.dataset.model;
      this.width = el.clientWidth;
      this.height = el.clientHeight;
      this.isRendering = false;
      this.angle = 0;
      this.radius = 50;
      this.retryCount = 0;

      this.init();
    }

    init() {
      this.observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !this.renderer) {
            this.setupScene();
          } else if (!entry.isIntersecting && this.renderer) {
            this.dispose();
          }
        });
      }, { threshold: 0.1 });

      this.observer.observe(this.container);
    }

    async setupScene() {
      if (this.retryCount > 5) return; // Prevent infinite loops
      
      try {
        this.scene = new THREE.Scene();
        this.camera = new THREE.PerspectiveCamera(60, this.width / this.height, 0.1, 200000);
        this.camera.position.set(-20.0, 200.0, 500);

        this.renderer = new THREE.WebGLRenderer({ antialias: true });
        
        // Check if context was successfully created
        if (!this.renderer.getContext()) {
          throw new Error("Context Creation Failed");
        }

        this.renderer.setClearColor(0x91d0f3, 1.0);
      this.renderer.setSize(this.width, this.height);
      this.renderer.outputEncoding = THREE.sRGBEncoding;
      this.renderer.toneMapping = THREE.ACESFilmicToneMapping;
      this.renderer.shadowMap.enabled = true;
      this.renderer.shadowMap.type = THREE.PCFSoftShadowMap;
      this.renderTarget.appendChild(this.renderer.domElement);

      this.controls = new OrbitControls(this.camera, this.renderer.domElement);
      this.controls.enableDamping = true;

      // Lights - Original settings
      this.ambientLight = new THREE.AmbientLight(0xffffff, 0.3);
      this.scene.add(this.ambientLight);

      this.directionalLight = new THREE.DirectionalLight(0x91d0f3, 1.3);
      this.directionalLight.position.set(-1.0, 110.0, 0.0);
      this.directionalLight.castShadow = true;
      this.directionalLight.shadow.mapSize.set(4096, 4096);
      this.directionalLight.shadow.camera.near = 0.5;
      this.directionalLight.shadow.camera.far = 5000;
      this.directionalLight.shadow.camera.left = -1000;
      this.directionalLight.shadow.camera.right = 1000;
      this.directionalLight.shadow.camera.top = 1000;
      this.directionalLight.shadow.camera.bottom = -10;
      this.directionalLight.shadow.bias = -0.01;

      const targetObject = new THREE.Object3D();
      targetObject.position.set(0, -1000, 0);
      this.directionalLight.target = targetObject;
      this.scene.add(this.directionalLight);

      // Model Loading
      const loader = new GLTFLoader();
      const gltf = await loader.loadAsync(this.modelUrl);
      
      this.group = [];
      gltf.scene.traverse((obj) => {
        obj.castShadow = true;
        obj.receiveShadow = true;
        if (obj.isMesh) {
          obj.material = new THREE.MeshToonMaterial({ color: 0x91d0f3 });
          obj.position.y = -8.5;
          obj.rotation.x = 0.25;
          this.group.push(obj);
          this.scene.add(obj);
        }
      });

      // Ground plane
      const planeGeo = new THREE.BoxGeometry(10000, 10000, 4);
      const planeMate = new THREE.MeshToonMaterial({ color: 0xf8f8f8 });
      const planeMesh = new THREE.Mesh(planeGeo, planeMate);
      planeMesh.rotation.x = 250;
      planeMesh.position.y = -40;
      planeMesh.receiveShadow = true;
      this.scene.add(planeMesh);

      this.isRendering = true;
      this.animate();
      window.addEventListener("resize", () => this.onResize());
      } catch (e) {
        console.warn("WebGL Context Busy, retrying in 1s...", e);
        this.retryCount++;
        setTimeout(() => this.setupScene(), 1000);
      }
    }

    dispose() {
      this.isRendering = false;
      if (!this.renderer) return;
      const extension = this.renderer.getContext().getExtension('WEBGL_lose_context');
      if (extension) extension.loseContext();
      this.renderer.dispose();
      this.renderer.domElement.remove();
      this.renderer = null;
      this.scene = null;
      this.camera = null;
      this.controls = null;
      this.group = [];
    }

    onResize() {
      if (!this.renderer) return;
      this.width = this.container.clientWidth;
      this.height = this.container.clientHeight;
      this.renderer.setSize(this.width, this.height);
      this.camera.aspect = this.width / this.height;
      this.camera.updateProjectionMatrix();
    }

    animate() {
      if (!this.isRendering) return;
      requestAnimationFrame(() => this.animate());
      
      this.angle += 0.003;
      const x = this.radius * Math.cos(this.angle);
      const z = this.radius * Math.sin(this.angle);
      if (this.directionalLight) this.directionalLight.position.set(x, 50, z);

      if (this.controls) this.controls.update();
      if (this.renderer && this.scene && this.camera) {
        this.renderer.render(this.scene, this.camera);
      }
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    const el = document.querySelector(".ml-city-container");
    if (el) new MLCityModel(el);
  });
</script>
