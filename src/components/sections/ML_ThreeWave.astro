---
// ML_ThreeWave.astro - 1:1 Original Implementation from ThreeJsWAVE-main
const { text = "Mina Lidya" } = Astro.props;
---
<div class="ml-three-wave-container" data-text={text}>
  <div id="ml-three-wave-render"></div>
  <div class="ml-wave-overlay">
    <h2>THREEJS WAVE</h2>
    <p>Canvas Texture & Vertex Displacement Dalgalanması</p>
  </div>
</div>

<style>
  .ml-three-wave-container {
    position: relative;
    width: 100%;
    height: 600px;
    background: #000;
    overflow: hidden;
  }

  #ml-three-wave-render {
    width: 100%;
    height: 100%;
  }

  .ml-wave-overlay {
    position: absolute;
    top: 40px;
    right: 40px;
    text-align: right;
    color: white;
    pointer-events: none;
    z-index: 10;
  }

  .ml-wave-overlay h2 {
    font-family: 'Cinzel', serif;
    font-size: 1.5rem;
    letter-spacing: 0.3em;
    margin-bottom: 5px;
  }

  .ml-wave-overlay p {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    opacity: 0.6;
  }
</style>

<script>
  import * as THREE from 'three';

  class MLThreeWave {
    constructor(el) {
      this.container = el;
      this.renderTarget = el.querySelector("#ml-three-wave-render");
      this.text = el.dataset.text;
      this.width = el.clientWidth;
      this.height = el.clientHeight;
      this.isRendering = false;
      this.time = 0;
      this.retryCount = 0;

      this.init();
    }

    init() {
      this.observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !this.renderer) {
            this.setupScene();
          } else if (!entry.isIntersecting && this.renderer) {
            this.dispose();
          }
        });
      }, { threshold: 0.1 });

      this.observer.observe(this.container);
    }

    createTexture() {
      const canvas = document.createElement("canvas");
      const ctx = canvas.getContext("2d");
      const fontSize = 800;
      const dpr = window.devicePixelRatio || 1;
      
      ctx.font = `bold ${fontSize * dpr}px 'Cinzel'`;
      const textWidth = ctx.measureText(this.text).width;
      
      canvas.width = textWidth;
      canvas.height = fontSize * dpr;

      ctx.fillStyle = "#000000";
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.font = `bold ${fontSize * dpr}px 'Cinzel'`;
      ctx.textBaseline = "middle";
      ctx.fillStyle = "#ffffff";
      ctx.fillText(this.text, 0, canvas.height / 2);

      const texture = new THREE.CanvasTexture(canvas);
      texture.minFilter = THREE.LinearFilter;
      texture.magFilter = THREE.LinearFilter;
      return texture;
    }

    async setupScene() {
      if (this.retryCount > 10) return;

      try {
        this.scene = new THREE.Scene();
        this.camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);
        
        this.renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        if (!this.renderer.getContext()) throw new Error("Context Failed");

        this.renderer.setClearColor(0x000000, 1);
        this.renderer.setSize(this.width, this.height);
        this.renderTarget.appendChild(this.renderer.domElement);

      const texture = this.createTexture();
      this.geometry = new THREE.PlaneGeometry(1.6, 0.8, 100, 100);

      this.material = new THREE.RawShaderMaterial({
        uniforms: {
          texture: { value: texture },
          uTime: { value: 0.0 }
        },
        vertexShader: `
          precision mediump float;
          uniform mat4 modelViewMatrix;
          uniform mat4 projectionMatrix;
          uniform float uTime;
          attribute vec3 position;
          attribute vec2 uv;
          varying vec2 vUv;

          void main() {
            vUv = uv;
            vec3 pos = position;
            float offset = 3.0;
            float freq = 0.005;
            float amp = 0.2;
            float PI = 3.14159265;

            pos.x = pos.x + sin(pos.y * offset + uTime * freq * PI ) * amp;
            pos.y = pos.y + sin(pos.x * offset + uTime * freq * PI ) * amp;

            gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
          }
        `,
        fragmentShader: `
          precision mediump float;
          uniform sampler2D texture;
          varying vec2 vUv;
          void main() {
            gl_FragColor = texture2D(texture, vUv);
          }
        `,
        transparent: true
      });

      this.mesh = new THREE.Mesh(this.geometry, this.material);
      this.scene.add(this.mesh);

      this.isRendering = true;
      this.animate();
      window.addEventListener("resize", () => this.onResize());
      } catch (e) {
        console.warn("ThreeWave WebGL busy, retrying...", e);
        this.retryCount++;
        setTimeout(() => this.setupScene(), 1000);
      }
    }

    dispose() {
      this.isRendering = false;
      if (!this.renderer) return;
      const extension = this.renderer.getContext().getExtension('WEBGL_lose_context');
      if (extension) extension.loseContext();
      this.renderer.dispose();
      this.renderer.domElement.remove();
      this.renderer = null;
      this.scene = null;
      this.camera = null;
      this.material = null;
      this.mesh = null;
    }

    onResize() {
      if (!this.renderer) return;
      this.width = this.container.clientWidth;
      this.height = this.container.clientHeight;
      this.renderer.setSize(this.width, this.height);
    }

    animate() {
      if (!this.isRendering) return;
      requestAnimationFrame(() => this.animate());
      this.time += 1;
      if (this.material) this.material.uniforms.uTime.value = this.time;
      if (this.renderer && this.scene && this.camera) {
        this.renderer.render(this.scene, this.camera);
      }
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    const el = document.querySelector(".ml-three-wave-container");
    if (el) new MLThreeWave(el);
  });
</script>
