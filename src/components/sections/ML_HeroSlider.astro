---
const slides = [
  { id: 1, title: "Gelinlik",          image: "/assets/images/gelinlik.webp" },
  { id: 2, title: "Tesettür Gelinlik", image: "/assets/images/tesettur.webp" },
  { id: 3, title: "Abiye & Gece",      image: "/assets/images/abiye.webp" },
  { id: 4, title: "After Party",       image: "/assets/images/after.webp" },
  { id: 5, title: "Kına Elbisesi",     image: "/assets/images/kina.webp" },
  { id: 6, title: "Özel Tasarım",      image: "/assets/images/1.webp" },
];
const total = slides.length;
---

<div class="showcase">
  <div class="showcase-filter"></div>

  <!-- WebGL canvas container — sticky, slides behind content -->
  <div id="showcase"></div>

  <!-- Scrollable slide list — overlaps sticky canvas via negative margin -->
  <section class="showcase-main">
    <ul class="showcase-main__ul">
      {slides.map((slide) => (
        <a href="#" class="showcase-main__li">
          <div class="showcase-main__image">
            <picture>
              <img
                src={slide.image}
                alt={slide.title}
                loading="eager"
                crossorigin="anonymous"
                class="showcase-media"
              />
            </picture>
          </div>
        </a>
      ))}
    </ul>
  </section>

  <!-- UI overlay — sticky to bottom, overlaps via negative margin -->
  <div class="showcase-head-cover">
    <div class="showcase-head__titles">
      <div class="showcase-head__titles-cover">
        <div class="showcase-head__titles-group">
          {slides.map((slide) => (
            <p class="c-head-font">{slide.title}</p>
          ))}
        </div>
      </div>
    </div>

    <div class="showcase-head">
      <h1 class="c-en-text--md">Showcase</h1>
      <div class="showcase-separate"></div>
      <div class="showcase-length c-en-text--md">
        <p><span class="current">01</span></p>
        <p>/</p>
        <p>{String(total).padStart(2, '0')}</p>
      </div>
    </div>
  </div>
</div>

<style>
  :root {
    font-size: 0.0694444444vw; /* 1rem = 1px at 1440px */
  }
  @media (max-width: 767px) {
    :root { font-size: 0.2666666667vw; }
  }

  .showcase {
    width: 100%;
    position: relative;
    background: #fff;
    overflow: clip; /* contains negative-margin children without breaking sticky */
    padding-top: 1px; /* ABSOLUTELY prevent margin-collapse with VideoHero */
    box-sizing: border-box;
  }

  /* ─── CANVAS LAYER ─────────────────────────────────── */
  #showcase {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100vh;
    z-index: 0;
    overflow: hidden;
  }

  /* ─── LOAD FADE OVERLAY ───────────────────────────── */
  .showcase-filter {
    position: absolute;   /* was fixed — fixed bleeds across all sections */
    inset: 0;
    background: #fff;
    z-index: 20;
    pointer-events: none;
    opacity: 0;
  }

  /* ─── SCROLL SLIDES ─────────────────────────────────── */
  /* Pulls the slide list up to overlap the sticky canvas  */
  .showcase-main {
    margin-top: -100vh;
    position: relative;
    z-index: 1;
  }

  .showcase-main__ul {
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .showcase-main__li {
    display: block;
    width: 100%;
    height: 100vh;
    position: relative;
    overflow: hidden;
  }

  /* Hidden img used only to give Three.js texture src + bounds */
  .showcase-main__image {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    z-index: -1;
  }

  .showcase-main__image .showcase-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ─── UI OVERLAY ─────────────────────────────────────── */
  .showcase-head-cover {
    position: sticky;
    bottom: 0;
    width: 100%;
    height: 100vh;
    margin-top: -100vh;   /* overlaps last slide */
    z-index: 3;
    pointer-events: none;
  }

  /* Centred title stack */
  .showcase-head__titles {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
  }

  .showcase-head__titles-cover {
    position: relative;
    overflow: visible;
    width: 600rem;
    max-width: 90vw;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* NO pseudo parens on cover — they live on .is-current inline */

  .showcase-head__titles-group {
    display: flex;
    flex-direction: column;
    gap: 2rem; /* minimum */
    position: relative;
  }

  .showcase-head__titles p {
    font-size: 13rem;
    line-height: 1.3;
    color: #111;
    opacity: 0.22;
    white-space: nowrap;
    font-weight: 400;
    letter-spacing: 0.02em;
    transition: opacity 0.35s, font-size 0.4s, font-weight 0.3s, color 0.3s;
  }

  /* Active item — inline parens, difference blend, bigger */
  .showcase-head__titles p.is-current {
    opacity: 1;
    font-size: 22rem;
    font-weight: 700;
    color: #ffffff;                 /* white required for difference */
    mix-blend-mode: difference;
    display: flex;
    align-items: center;
    gap: 6rem;
  }

  .showcase-head__titles p.is-current::before { content: "("; }
  .showcase-head__titles p.is-current::after  { content: ")"; }

  /* Bottom counter bar */
  .showcase-head {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 24rem;
    padding: 10rem 24rem;
    background: #fff;
    border: 1px solid #e0e0e0;
    pointer-events: auto;
  }

  .showcase-head h1 {
    font-size: 13rem;
    color: #111;
    margin: 0;
  }

  .showcase-separate {
    width: 1px;
    height: 14rem;
    background: #ddd;
  }

  .showcase-length {
    display: flex;
    align-items: center;
    gap: 6rem;
    font-size: 13rem;
    color: #111;
  }
  .showcase-length .current {
    min-width: 20rem;
    text-align: right;
  }
</style>

<script is:inline>
  (function initMLHeroSlider() {
    console.log('DIAG: ML_HeroSlider init start');
    const container = document.querySelector(".showcase-main");
    if (!container) return;
    
    const checkGlobals = setInterval(() => {
        if (window.ML_HeroSlider) {
            clearInterval(checkGlobals);
            if (!window._sliderInstance) {
                window._sliderInstance = new window.ML_HeroSlider();
            }
        }
    }, 50);

    // Document Swup hook for cleanup
    document.addEventListener("swup:contentReplaced", () => {
        if (window._sliderInstance && window._sliderInstance.observer) {
            window._sliderInstance.observer.disconnect();
            window._sliderInstance = null;
        }
    });
  })();
</script>
