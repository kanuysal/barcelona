---
// ML_RoomBlender.astro - 1:1 Original Implementation from RoomBlender-main
const { modelUrl = "/assets/images/room.glb" } = Astro.props;
---
<div class="ml-room-blender-container" data-model={modelUrl}>
  <div id="ml-room-render"></div>
  <div class="ml-room-overlay">
    <h2>ROOM BLENDER III</h2>
    <p>3D Mekan Render & Dinamik Perlin Noise Işıklandırma</p>
  </div>
</div>

<style>
  .ml-room-blender-container {
    position: relative;
    width: 100%;
    height: 700px;
    background: #111;
    overflow: hidden;
    cursor: grab;
  }

  .ml-room-blender-container:active {
    cursor: grabbing;
  }

  #ml-room-render {
    width: 100%;
    height: 100%;
  }

  .ml-room-overlay {
    position: absolute;
    top: 40px;
    right: 40px;
    text-align: right;
    color: white;
    pointer-events: none;
    z-index: 10;
  }

  .ml-room-overlay h2 {
    font-family: 'Cinzel', serif;
    font-size: 1.5rem;
    letter-spacing: 0.3em;
    margin-bottom: 5px;
  }

  .ml-room-overlay p {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    opacity: 0.6;
  }
</style>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';
  import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';

  class MLRoomBlender {
    constructor(el) {
      this.container = el;
      this.renderTarget = el.querySelector("#ml-room-render");
      this.modelUrl = el.dataset.model;
      this.width = el.clientWidth;
      this.height = el.clientHeight;
      this.isRendering = false;
      this.retryCount = 0;
      this.angle = 0;
      this.radius = 200;
      this.group = [];

      this.init();
    }

    init() {
      // Handled by Toggle Buttons in elements3
      this.setupScene();
    }

    async setupScene() {
      if (this.retryCount > 10) return;

      try {
        this.scene = new THREE.Scene();
        this.camera = new THREE.PerspectiveCamera(60, this.width / this.height, 0.01, 200000);
        this.camera.position.set(0, 0, 15);

        this.renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        if (!this.renderer.getContext()) throw new Error("Context Failed");

        this.renderer.setClearColor(0x111111, 1);
        this.renderer.setSize(this.width, this.height);
        this.renderer.outputEncoding = THREE.sRGBEncoding;
        this.renderer.toneMapping = THREE.ACESFilmicToneMapping;
        this.renderer.toneMappingExposure = 1.75;
        this.renderer.shadowMap.enabled = true;
        this.renderTarget.appendChild(this.renderer.domElement);

        this.controls = new OrbitControls(this.camera, this.renderer.domElement);
        this.controls.enableDamping = true;

        this.ambientLight = new THREE.AmbientLight(0xffffff, 0.1);
        this.directionalLight1 = new THREE.DirectionalLight(0xffffff, 0.5);
        this.directionalLight2 = new THREE.DirectionalLight(0xffffff, 0.92);
        this.scene.add(this.ambientLight, this.directionalLight1, this.directionalLight2);

        const loader = new GLTFLoader();
        const gltf = await loader.loadAsync(this.modelUrl);
        
        const vertexShader = `
          vec4 permute(vec4 x){return mod(((x*34.0)+1.0)*x, 289.0);}
          vec4 taylorInvSqrt(vec4 r){return 1.79284291400159 - 0.85373472095314 * r;}
          vec3 fade(vec3 t) {return t*t*t*(t*(t*6.0-15.0)+10.0);}
          float cnoise(vec3 P){
            vec3 Pi0 = floor(P); vec3 Pi1 = Pi0 + vec3(1.0);
            Pi0 = mod(Pi0, 289.0); Pi1 = mod(Pi1, 289.0);
            vec3 Pf0 = fract(P); vec3 Pf1 = Pf0 - vec3(1.0);
            vec4 ix = vec4(Pi0.x, Pi1.x, Pi0.x, Pi1.x); vec4 iy = vec4(Pi0.yy, Pi1.yy);
            vec4 iz0 = Pi0.zzzz; vec4 iz1 = Pi1.zzzz;
            vec4 ixy = permute(permute(ix) + iy);
            vec4 ixy0 = permute(ixy + iz0); vec4 ixy1 = permute(ixy + iz1);
            vec4 gx0 = ixy0 / 7.0; vec4 gy0 = fract(floor(gx0) / 7.0) - 0.5;
            gx0 = fract(gx0); vec4 gz0 = vec4(0.5) - abs(gx0) - abs(gy0);
            vec4 sz0 = step(gz0, vec4(0.0)); gx0 -= sz0 * (step(0.0, gx0) - 0.5); gy0 -= sz0 * (step(0.0, gy0) - 0.5);
            vec4 gx1 = ixy1 / 7.0; vec4 gy1 = fract(floor(gx1) / 7.0) - 0.5;
            gx1 = fract(gx1); vec4 gz1 = vec4(0.5) - abs(gx1) - abs(gy1);
            vec4 sz1 = step(gz1, vec4(0.0)); gx1 -= sz1 * (step(0.0, gx1) - 0.5); gy1 -= sz1 * (step(0.0, gy1) - 0.5);
            vec3 g000 = vec3(gx0.x,gy0.x,gz0.x); vec3 g100 = vec3(gx0.y,gy0.y,gz0.y);
            vec3 g010 = vec3(gx0.z,gy0.z,gz0.z); vec3 g110 = vec3(gx0.w,gy0.w,gz0.w);
            vec3 g001 = vec3(gx1.x,gy1.x,gz1.x); vec3 g101 = vec3(gx1.y,gy1.y,gz1.y);
            vec3 g011 = vec3(gx1.z,gy1.z,gz1.z); vec3 g111 = vec3(gx1.w,gy1.w,gz1.w);
            vec4 norm0 = taylorInvSqrt(vec4(dot(g000, g000), dot(g010, g010), dot(g100, g100), dot(g110, g110)));
            g000 *= norm0.x; g010 *= norm0.y; g100 *= norm0.z; g110 *= norm0.w;
            vec4 norm1 = taylorInvSqrt(vec4(dot(g001, g001), dot(g011, g011), dot(g101, g101), dot(g111, g111)));
            g001 *= norm1.x; g011 *= norm1.y; g101 *= norm1.z; g111 *= norm1.w;
            float n000 = dot(g000, Pf0); float n100 = dot(g100, vec3(Pf1.x, Pf0.yz));
            float n010 = dot(g010, vec3(Pf0.x, Pf1.y, Pf0.z)); float n110 = dot(g110, vec3(Pf1.xy, Pf0.z));
            float n001 = dot(g001, vec3(Pf0.xy, Pf1.z)); float n101 = dot(g101, vec3(Pf1.x, Pf0.y, Pf1.z));
            float n011 = dot(g011, vec3(Pf0.x, Pf1.yz)); float n111 = dot(g111, Pf1);
            vec3 fade_xyz = fade(Pf0);
            vec4 n_z = mix(vec4(n000, n100, n010, n110), vec4(n001, n101, n011, n111), fade_xyz.z);
            vec2 n_yz = mix(n_z.xy, n_z.zw, fade_xyz.y);
            return 2.2 * mix(n_yz.x, n_yz.y, fade_xyz.x);
          }

          varying vec2 vUv;
          uniform float uTime;
          varying float vNoise;
          varying vec3 vNormal;

          void main() {
            vec3 pos = position;
            float noise = cnoise(vec3(pos.x*0.1+uTime, pos.y*0.1+uTime, pos.z*0.1+uTime));
            vNoise = noise;
            vUv = uv;
            vNormal = normalize(normalMatrix * normal);
            gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
          }
        `;

        const fragmentShader = `
          precision mediump float;
          #include <common>
          #include <lights_pars_begin>
          varying float vNoise;
          varying vec2 vUv;
          varying vec3 vNormal;
          uniform vec3 uColor;

          void main() {
            float NdotL = dot(vNormal, directionalLights[0].direction);
            float NdotL2 = dot(vNormal, directionalLights[1].direction);
            float intensity = smoothstep(0.0, 0.1, NdotL);
            float intensity2 = smoothstep(0.0, 0.1, NdotL2);

            vec3 light = directionalLights[0].color * intensity;
            vec3 light2 = directionalLights[1].color * intensity2;
               
            vec3 color1 = vec3(0.3, 0.5, 0.5);
            vec3 color2 = vec3(0.5, 0.45, 0.2); 
            vec3 noiseColor = mix(color1, color2, 0.2 * (vNoise * 10.0));

            gl_FragColor = vec4(uColor * (ambientLightColor + light + light2), 1.0) * vec4(noiseColor, 1.0);
          }
        `;

        gltf.scene.traverse((obj) => {
          if (obj.isMesh) {
            const material = new THREE.ShaderMaterial({
              vertexShader,
              fragmentShader,
              lights: true,
              uniforms: {
                ...THREE.UniformsLib.lights,
                uColor: { value: new THREE.Color(0xffffff) },
                uTime: { value: 0.0 }
              },
              side: THREE.DoubleSide
            });
            obj.material = material;
            this.group.push(obj);
          }
        });

        this.scene.add(gltf.scene);
        gltf.scene.position.y = -1;
        gltf.scene.rotation.x = 0.2;

        this.isRendering = true;
        this.animate();
        window.addEventListener("resize", () => this.onResize());
      } catch (e) {
        console.warn("RoomBlender WebGL busy, retrying in 1.5s...", e);
        this.retryCount++;
        setTimeout(() => this.setupScene(), 1500);
      }
    }

    dispose() {
      this.isRendering = false;
      if (!this.renderer) return;
      
      const extension = this.renderer.getContext().getExtension('WEBGL_lose_context');
      if (extension) extension.loseContext();
      this.renderer.dispose();
      this.renderer.domElement.remove();
      this.renderer = null;
      this.scene = null;
      this.camera = null;
      this.group = [];
    }

    onResize() {
      if (!this.renderer) return;
      this.width = this.container.clientWidth;
      this.height = this.container.clientHeight;
      this.renderer.setSize(this.width, this.height);
      this.camera.aspect = this.width / this.height;
      this.camera.updateProjectionMatrix();
    }

    animate() {
      if (!this.isRendering) return;
      requestAnimationFrame(() => this.animate());
      
      this.angle += 0.01;
      const x = this.radius * Math.cos(this.angle);
      const z = this.radius * Math.sin(this.angle);
      if (this.directionalLight1) this.directionalLight1.position.set(x, 200, z);
      if (this.directionalLight2) this.directionalLight2.position.set(-x, 200, z);

      this.group.forEach(obj => {
        obj.material.uniforms.uTime.value += 0.005;
        obj.rotation.y += 0.002;
      });

      if (this.controls) this.controls.update();
      if (this.renderer && this.scene && this.camera) {
        this.renderer.render(this.scene, this.camera);
      }
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    const el = document.querySelector(".ml-room-blender-container");
    if (!el) return;
    
    let instance = null;
    window.addEventListener('ml-init-22', () => {
      try {
        if (!instance) instance = new MLRoomBlender(el);
      } catch (err) {
        el.innerHTML = `<div style="color:#ff4444; padding:20px; font-family:monospace; font-size:12px;">Three.js Error: ${err.message}</div>`;
      }
    });

    window.addEventListener('ml-dispose-22', () => {
      if (instance) {
        instance.dispose();
        instance = null;
      }
    });
  });
</script>
