---
// ML_ParticleMorphing.astro - 1:1 Original Implementation from ThreeJsParticleMorphing-main
---
<div class="ml-particle-morph-container">
  <div id="ml-morph-render"></div>
  <div class="ml-morph-overlay">
    <h2>PARTICLE MORPHING</h2>
    <p>50,000 Parçacık ile Geometrik Dönüşüm (Box to Sphere)</p>
  </div>
</div>

<style>
  .ml-particle-morph-container {
    position: relative;
    width: 100%;
    height: 700px;
    background: #111;
    overflow: hidden;
  }

  #ml-morph-render {
    width: 100%;
    height: 100%;
  }

  .ml-morph-overlay {
    position: absolute;
    bottom: 40px;
    left: 40px;
    color: white;
    pointer-events: none;
    z-index: 10;
  }

  .ml-morph-overlay h2 {
    font-family: 'Cinzel', serif;
    font-size: 1.5rem;
    letter-spacing: 0.3em;
    margin-bottom: 5px;
  }

  .ml-morph-overlay p {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    opacity: 0.6;
  }
</style>

<script>
  import * as THREE from 'three';
  import { MeshSurfaceSampler } from 'three/examples/jsm/math/MeshSurfaceSampler.js';
  import { gsap, Power4 } from 'gsap';

  class MLParticleMorphing {
    constructor(el) {
      this.container = el;
      this.renderTarget = el.querySelector("#ml-morph-render");
      this.width = el.clientWidth;
      this.height = el.clientHeight;
      this.isRendering = false;
      this.retryCount = 0;
      
      this.init();
    }

    init() {
      // Logic is now handled by external toggle buttons
      this.setupScene();
    }

    _getGeometryPoints(geo) {
      const particleCount = 50000;
      const material = new THREE.MeshBasicMaterial();
      const mesh = new THREE.Mesh(geo, material);
      const sampler = new MeshSurfaceSampler(mesh).build();
      const points = new Float32Array(particleCount * 3);

      for (let i = 0; i < particleCount; i++) {
        const vertex = new THREE.Vector3();
        sampler.sample(vertex);
        points.set([vertex.x, vertex.y, vertex.z], i * 3);
      }
      return points;
    }

    async setupScene() {
      if (this.retryCount > 10) return;

      try {
        this.scene = new THREE.Scene();
        this.camera = new THREE.PerspectiveCamera(60, this.width / this.height, 0.1, 20000);
        this.camera.position.z = 40;

        this.renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        if (!this.renderer.getContext()) throw new Error("Context Failed");

        this.renderer.setClearColor(0x111111, 1);
        this.renderer.setSize(this.width, this.height);
        this.renderTarget.appendChild(this.renderer.domElement);

        const pointsBox = this._getGeometryPoints(new THREE.BoxGeometry(15, 15, 15));
        const pointsSphere = this._getGeometryPoints(new THREE.SphereGeometry(12, 32, 32));

        this.geometry = new THREE.BufferGeometry();
        this.geometry.setAttribute("position", new THREE.BufferAttribute(pointsBox, 3));
        this.geometry.setAttribute("two", new THREE.BufferAttribute(pointsSphere, 3));

        this.material = new THREE.RawShaderMaterial({
          uniforms: {
            uPoint01: { value: 0.0 },
          },
          vertexShader: `
            precision mediump float;
            attribute vec3 position;
            attribute vec3 two;
            uniform float uPoint01;
            uniform mat4 modelViewMatrix;
            uniform mat4 projectionMatrix;

            void main() {
              vec3 morphing = mix(position, two, clamp(uPoint01, 0.0, 1.0));
              gl_Position = projectionMatrix * modelViewMatrix * vec4(morphing, 1.0);
              gl_PointSize = 2.0;
            }
          `,
          fragmentShader: `
            precision mediump float;
            void main() {
              vec2 temp = gl_PointCoord - vec2(0.5);
              float f = dot(temp, temp);
              if (f > 0.2) discard;
              gl_FragColor = vec4(0.3, 0.7, 1.0, 0.8);
            }
          `,
          transparent: true,
          blending: THREE.AdditiveBlending,
        });

        this.mesh = new THREE.Points(this.geometry, this.material);
        this.scene.add(this.mesh);

        this.tl = gsap.timeline({ repeat: -1, repeatDelay: 1 });
        this.tl.to(this.material.uniforms.uPoint01, {
          value: 1.0,
          ease: "Power4.easeInOut",
          duration: 3,
        })
        .to(this.material.uniforms.uPoint01, {
          value: 0.0,
          ease: "Power4.easeInOut",
          delay: 1,
          duration: 3,
        });

        this.isRendering = true;
        this.animate();
        window.addEventListener("resize", () => this.onResize());
      } catch (e) {
        console.warn("ParticleMorphing WebGL busy, retrying in 1s...", e);
        this.retryCount++;
        setTimeout(() => this.setupScene(), 1000);
      }
    }

    dispose() {
      this.isRendering = false;
      if (this.tl) this.tl.kill();
      if (!this.renderer) return;
      
      const extension = this.renderer.getContext().getExtension('WEBGL_lose_context');
      if (extension) extension.loseContext();
      this.renderer.dispose();
      this.renderer.domElement.remove();
      this.renderer = null;
      this.scene = null;
      this.camera = null;
      this.mesh = null;
    }

    onResize() {
      if (!this.renderer) return;
      this.width = this.container.clientWidth;
      this.height = this.container.clientHeight;
      this.renderer.setSize(this.width, this.height);
      this.camera.aspect = this.width / this.height;
      this.camera.updateProjectionMatrix();
    }

    animate() {
      if (!this.isRendering) return;
      requestAnimationFrame(() => this.animate());
      this.mesh.rotation.x += 0.005;
      this.mesh.rotation.y += 0.005;
      if (this.renderer && this.scene && this.camera) {
        this.renderer.render(this.scene, this.camera);
      }
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    const el = document.querySelector(".ml-particle-morph-container");
    if (!el) return;
    
    let instance = null;

    window.addEventListener('ml-init-21', () => {
      try {
        if (!instance) instance = new MLParticleMorphing(el);
      } catch (err) {
        el.innerHTML = `<div style="color:#ff4444; padding:20px; font-family:monospace; font-size:12px;">Three.js Error: ${err.message}</div>`;
      }
    });

    window.addEventListener('ml-dispose-21', () => {
      if (instance) {
        instance.dispose();
        instance = null;
      }
    });
  });
</script>
