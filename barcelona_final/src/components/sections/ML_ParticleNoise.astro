---
// ML_ParticleNoise.astro - 1:1 Original Implementation from ThreeJsParticleNoise-main
---
<div class="ml-particle-noise-container">
  <div id="ml-noise-render"></div>
  <div class="ml-noise-overlay">
    <h2>PARTICLE NOISE</h2>
    <p>Simplex Noise Algoritması ile 100,000 Dinamik Parçacık</p>
  </div>
</div>

<style>
  .ml-particle-noise-container {
    position: relative;
    width: 100%;
    height: 700px;
    background: #000;
    overflow: hidden;
  }

  #ml-noise-render {
    width: 100%;
    height: 100%;
  }

  .ml-noise-overlay {
    position: absolute;
    bottom: 40px;
    left: 40px;
    color: white;
    pointer-events: none;
    z-index: 10;
  }

  .ml-noise-overlay h2 {
    font-family: 'Cinzel', serif;
    font-size: 1.5rem;
    letter-spacing: 0.3em;
    margin-bottom: 5px;
  }

  .ml-noise-overlay p {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    opacity: 0.6;
  }
</style>

<script>
  import * as THREE from 'three';
  import { MeshSurfaceSampler } from 'three/examples/jsm/math/MeshSurfaceSampler.js';

  class MLParticleNoise {
    constructor(el) {
      this.container = el;
      this.renderTarget = el.querySelector("#ml-noise-render");
      this.width = el.clientWidth;
      this.height = el.clientHeight;
      this.isRendering = false;
      this.time = 0;
      this.retryCount = 0;

      this.init();
    }

    init() {
      this.observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !this.renderer) {
            this.setupScene();
          } else if (!entry.isIntersecting && this.renderer) {
            this.dispose();
          }
        });
      }, { threshold: 0.1 });

      this.observer.observe(this.container);
    }

    async setupScene() {
      if (this.retryCount > 10) return;
      
      try {
        this.scene = new THREE.Scene();
        this.camera = new THREE.PerspectiveCamera(60, this.width / this.height, 0.1, 20000);
        this.camera.position.z = 15;

        this.renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        if (!this.renderer.getContext()) throw new Error("Context Failed");

        this.renderer.setClearColor(0x000000, 1);
        this.renderer.setSize(this.width, this.height);
        this.renderTarget.appendChild(this.renderer.domElement);

      const particleNumber = 100000;
      const boxGeo = new THREE.BoxGeometry(10, 10, 10, 100, 100, 100);
      const sphereGeo = new THREE.SphereGeometry(10, 100, 100);
      
      const samplerBox = new MeshSurfaceSampler(new THREE.Mesh(boxGeo)).build();
      const samplerSphere = new MeshSurfaceSampler(new THREE.Mesh(sphereGeo)).build();
      
      const pos1 = new Float32Array(particleNumber * 3);
      const pos2 = new Float32Array(particleNumber * 3);
      const tempV = new THREE.Vector3();

      for (let i = 0; i < particleNumber; i++) {
        samplerBox.sample(tempV);
        pos1.set([tempV.x, tempV.y, tempV.z], i * 3);
        samplerSphere.sample(tempV);
        pos2.set([tempV.x, tempV.y, tempV.z], i * 3);
      }

      this.geometry = new THREE.BufferGeometry();
      this.geometry.setAttribute("position", new THREE.BufferAttribute(pos1, 3));
      this.geometry.setAttribute("two", new THREE.BufferAttribute(pos2, 3));

      this.material = new THREE.RawShaderMaterial({
        uniforms: {
          uPoint01: { value: 0.0 },
          uTime: { value: 0.0 },
          uSize: { value: 1.5 } // Keep it visible but elegant
        },
        vertexShader: `
          precision mediump float;
          attribute vec3 position;
          attribute vec3 two;
          uniform float uPoint01;
          uniform float uTime;
          uniform float uSize;
          uniform mat4 modelViewMatrix;
          uniform mat4 projectionMatrix;

          vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
          vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
          vec3 permute(vec3 x) { return mod289(((x*34.0)+10.0)*x); }

          float snoise(vec2 v) {
            const vec4 C = vec4(0.211324865405187, 0.366025403784439, -0.577350269189626, 0.024390243902439);
            vec2 i  = floor(v + dot(v, C.yy) );
            vec2 x0 = v - i + dot(i, C.xx);
            vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
            vec4 x12 = x0.xyxy + C.xxzz;
            x12.xy -= i1;
            i = mod289(i);
            vec3 p = permute( permute( i.y + vec3(0.0, i1.y, 1.0 )) + i.x + vec3(0.0, i1.x, 1.0 ));
            vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy), dot(x12.zw,x12.zw)), 0.0);
            m = m*m; m = m*m;
            vec3 x = 2.0 * fract(p * C.www) - 1.0;
            vec3 h = abs(x) - 0.5;
            vec3 ox = floor(x + 0.5);
            vec3 a0 = x - ox;
            m *= 1.79284291400159 - 0.85373472095314 * ( a0*a0 + h*h );
            vec3 g;
            g.x  = a0.x  * x0.x  + h.x  * x0.y;
            g.yz = a0.yz * x12.xz + h.yz * x12.yw;
            return 1000.0 * dot(m, g);
          }

          void main() {
            vec3 morphing = mix(position, two, uPoint01);
            float PI = 3.14159265;
            morphing.x += snoise(normalize(morphing.xy)) * sin(morphing.y + uTime * PI) * 0.5;
            morphing.y += snoise(normalize(morphing.xy)) * cos(morphing.x + uTime * PI) * 0.5;
            morphing.z += snoise(normalize(morphing.xy)) * sin(morphing.y + uTime * PI) * 0.5;

            gl_Position = projectionMatrix * modelViewMatrix * vec4(morphing, 1.0 );
            gl_PointSize = uSize;
          }
        `,
        fragmentShader: `
          precision mediump float;
          void main() {
            vec2 temp = gl_PointCoord - vec2(0.5);
            float f = dot(temp, temp);
            if (f > 0.25) discard;
            gl_FragColor = vec4(1.0, 1.0, 1.0, 1.0);
          }
        `,
        transparent: true,
        blending: THREE.AdditiveBlending
      });

      this.mesh = new THREE.Points(this.geometry, this.material);
      this.scene.add(this.mesh);

      this.isRendering = true;
      this.animate();
      window.addEventListener("resize", () => this.onResize());
      } catch (e) {
        console.warn("ParticleNoise WebGL busy, retrying...", e);
        this.retryCount++;
        setTimeout(() => this.setupScene(), 1000);
      }
    }

    dispose() {
      this.isRendering = false;
      if (!this.renderer) return;
      const extension = this.renderer.getContext().getExtension('WEBGL_lose_context');
      if (extension) extension.loseContext();
      this.renderer.dispose();
      this.renderer.domElement.remove();
      this.renderer = null;
      this.scene = null;
      this.camera = null;
      this.material = null;
      this.mesh = null;
    }

    onResize() {
      if (!this.renderer) return;
      this.width = this.container.clientWidth;
      this.height = this.container.clientHeight;
      this.renderer.setSize(this.width, this.height);
      this.camera.aspect = this.width / this.height;
      this.camera.updateProjectionMatrix();
    }

    animate() {
      if (!this.isRendering) return;
      requestAnimationFrame(() => this.animate());
      this.time += 0.0005;
      if (this.material) this.material.uniforms.uTime.value = this.time;
      if (this.renderer && this.scene && this.camera) {
        this.renderer.render(this.scene, this.camera);
      }
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    const el = document.querySelector(".ml-particle-noise-container");
    if (el) new MLParticleNoise(el);
  });
</script>
