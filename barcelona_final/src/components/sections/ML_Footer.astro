      <button class="ml-footer__backtop" id="backToTop">
        <span>Geri Dön ↑</span>
      </button>
    </div>

  </div>
</footer>

<style>
  /* ─── ROOT REM SCALE ───────────────────────────────────── */
  .ml-footer {
    --side-pad: 48px;
    --col-gap: 16px;
    font-size: 0.0694444444vw; /* 1rem = 1px @1440 */
    background: #ffffff;
    color: #111;
  }
  @media (max-width: 767px) {
    .ml-footer {
      font-size: 0.2666666667vw;
      --side-pad: 20px;
    }
  }

  /* ─── FOOTER BASE ───────────────────────────────────────── */
  .ml-footer {
    width: 100%;
    padding-top: 100rem;
    padding-bottom: 20rem;
    border-top: 1px solid #f0f0f0;
    position: relative;
    z-index: 10;
  }

  .ml-footer__inner {
    padding-inline: var(--side-pad);
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: var(--col-gap);
    position: relative;
  }
  @media (min-width: 768px) {
    .ml-footer__inner { min-height: 540rem; }
  }
  @media (max-width: 767px) {
    .ml-footer__inner { display: flex; flex-direction: column; gap: 40rem; }
  }

  /* ─── COLUMNS ─────────────────────────────────────────── */
  .ml-footer__contents[data-column="1"] { grid-column: 1 / span 3; }
  .ml-footer__contents[data-column="2"] { grid-column: 5 / span 3; }
  .ml-footer__contents[data-column="3"] { grid-column: 9 / span 4; }

  .ml-footer__contents-ul {
    display: flex;
    flex-direction: column;
    gap: 60rem;
  }
  @media (max-width: 767px) { .ml-footer__contents-ul { gap: 30rem; } }

  .ml-footer__contents-li {
    display: flex;
    flex-direction: column;
    gap: 14rem;
  }

  /* Titles in Cinzel */
  .ml-footer__contents-li .title {
    font-family: 'Cinzel', serif;
    font-size: 11rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.5;
  }

  /* Links in EB Garamond */
  .ml-footer__contents-li .text {
    display: flex;
    flex-wrap: wrap;
    font-family: 'EB Garamond', serif;
    font-size: 15rem;
    line-height: 1.6;
  }
  
  .ml-footer__contents-li .text a {
    color: #111;
    text-decoration: none;
    margin-right: 8rem;
    transition: opacity 0.3s;
    border-bottom: 1px solid transparent;
  }
  .ml-footer__contents-li .text a:hover { opacity: 0.5; border-bottom-color: #111; }

  .ml-footer .info-row { font-family: 'EB Garamond', serif; font-size: 15rem; color: #111; }
  .ml-footer .info-contact { margin-top: 4rem; }
  .ml-footer .info-contact a { border-bottom: 1px solid #eee; }

  /* ─── LARGE BOTTOM TEXT ───────────────────────────────── */
  .ml-footer__under {
    grid-column: 1 / span 12;
    grid-row: 2;
    padding-top: 80rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    margin-top: 60rem;
  }
  @media (max-width: 767px) { .ml-footer__under { order: 10; padding-top: 40rem; } }

  .ml-footer__under-text {
    font-family: 'Cinzel', serif;
    font-size: clamp(40rem, 15vw, 240rem);
    line-height: 0.85;
    letter-spacing: -0.01em;
    display: flex;
    justify-content: center;
    overflow: hidden;
    color: #111;
  }

  .ml-footer__under-text .chars {
    display: block;
    transform: translateY(110%);
    will-change: transform;
  }

  .ml-footer__under-sub {
    font-family: 'Cinzel', serif;
    font-size: 12rem;
    letter-spacing: 0.3em;
    margin-top: 24rem;
    opacity: 0.6;
    text-transform: uppercase;
  }
  @media (max-width: 767px) { .ml-footer__under-sub { font-size: 10rem; letter-spacing: 0.15em; } }

  /* ─── COPYRIGHT & BACKTOP ─────────────────────────────── */
  .ml-footer__bottom {
    grid-column: 1 / span 12;
    grid-row: 3;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 60rem;
    font-family: 'EB Garamond', serif;
    font-size: 11rem;
    letter-spacing: 0.05em;
  }
  @media (max-width: 767px) { .ml-footer__bottom { flex-direction: column; gap: 20rem; } }

  #backToTop {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 12rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #111;
    transition: opacity 0.3s;
    font-family: 'Cinzel', serif;
  }
  #backToTop:hover { opacity: 0.5; }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    // Big Branding Text Animation
    gsap.to('.ml-footer__under-text .chars', {
      y: '0%',
      duration: 1.5,
      ease: 'power4.out',
      stagger: { from: 'start', each: 0.05 },
      scrollTrigger: {
        trigger: '.ml-footer__under',
        start: 'top 90%',
      }
    });

    // Back to top click
    const btn = document.getElementById('backToTop');
    if (btn) {
      btn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  });
</script>
