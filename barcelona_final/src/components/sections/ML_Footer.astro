    <!-- Large Bottom Branding -->
    <div class="ml-footer__under" data-split="container">
      <p class="ml-footer__under-text" data-split="inner" aria-label="MİNA LİDYA">
        <span class="chars">M</span>
        <span class="chars">İ</span>
        <span class="chars">N</span>
        <span class="chars">A</span>
        <span class="chars">&nbsp;</span>
        <span class="chars">L</span>
        <span class="chars">İ</span>
        <span class="chars">D</span>
        <span class="chars">Y</span>
