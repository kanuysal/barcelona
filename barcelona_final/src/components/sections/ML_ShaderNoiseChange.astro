---
// ML_ShaderNoiseChange.astro - 1:1 Original Implementation from ShaderNoiseChange-main
const { 
  img1 = "wide (24).jpeg", 
  img2 = "wide (25).jpeg", 
  noise = "noise.webp" 
} = Astro.props;
---
<div class="ml-shader-noise-container" data-img1={img1} data-img2={img2} data-noise={noise}>
  <div id="ml-shader-noise-render"></div>
  <div class="ml-noise-overlay">
    <h2>SHADER NOISE CHANGE</h2>
    <p>Akışkan Geçiş Algoritması & Noise Distorsiyonu</p>
  </div>
</div>

<style>
  .ml-shader-noise-container {
    position: relative;
    width: 100%;
    height: 700px;
    background: #111;
    overflow: hidden;
  }

  #ml-shader-noise-render {
    width: 100%;
    height: 100%;
  }

  .ml-noise-overlay {
    position: absolute;
    bottom: 40px;
    right: 40px;
    text-align: right;
    color: white;
    pointer-events: none;
    z-index: 10;
  }

  .ml-noise-overlay h2 {
    font-family: 'Cinzel', serif;
    font-size: 1.5rem;
    letter-spacing: 0.3em;
    margin-bottom: 5px;
  }

  .ml-noise-overlay p {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    opacity: 0.6;
  }
</style>
<script is:inline>
  class MLShaderNoiseChange {
    constructor(el) {
      this.container = el;
      this.renderTarget = el.querySelector("#ml-shader-noise-render");
      this.textures = {
        t1: `/assets/images/${el.dataset.img1.replace(/\.(jpg|jpeg|png)$/i, '.webp')}`,
        t2: `/assets/images/${el.dataset.img2.replace(/\.(jpg|jpeg|png)$/i, '.webp')}`,
        noise: `/assets/images/${el.dataset.noise.replace(/\.(jpg|jpeg|png)$/i, '.webp')}`
      };
      this.width = el.clientWidth;
      this.height = el.clientHeight;
      this.isRendering = false;
      this.init();
    }

    async init() {
      if (!window.waitForGlobals) return;
      const globals = await window.waitForGlobals();
      const THREE = globals.THREE;
      const gsap = globals.gsap;

      this.observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !this.renderer) {
            this.setupScene(THREE, gsap);
          } else if (!entry.isIntersecting && this.renderer) {
            this.dispose();
          }
        });
      }, { threshold: 0.1 });

      this.observer.observe(this.container);
    }

    async setupScene(THREE, gsap) {
      this.scene = new THREE.Scene();
      this.camera = new THREE.PerspectiveCamera(60, this.width / this.height, 0.01, 1000);
      this.camera.position.z = 10.5;
      this.renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
      this.renderer.setSize(this.width, this.height);
      this.renderTarget.appendChild(this.renderer.domElement);

      const loader = new THREE.TextureLoader();
      const [t1, t2, n] = await Promise.all([
        loader.loadAsync(this.textures.t1),
        loader.loadAsync(this.textures.t2),
        loader.loadAsync(this.textures.noise)
      ]);

      this.geometry = new THREE.PlaneGeometry(6, 8);
      this.material = new THREE.ShaderMaterial({
        uniforms: {
          uCurrentTexture: { value: t1 },
          uNextTexture: { value: t2 },
          uChangeTransition: { value: 0.0 },
          disp: { value: n }
        },
        vertexShader: `
          varying vec2 vUv;
          void main(){
            vUv = uv;
            gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
          }
        `,
        fragmentShader: `
          varying vec2 vUv;
          uniform sampler2D uCurrentTexture;
          uniform sampler2D uNextTexture;
          uniform sampler2D disp;
          uniform float uChangeTransition;

          void main() {
            vec2 uv = vUv;
            vec4 d = texture2D(disp, uv);
            vec2 dispVec = vec2(d.x, d.y);
            vec2 distPos1 = uv + (dispVec * 1.0 * uChangeTransition);
            vec2 distPos2 = uv + (dispVec * -(1.0 * (5.0 - uChangeTransition)));
            vec4 currentImages = texture2D(uCurrentTexture, vec2(uv.x, uv.y + uChangeTransition * (0.1)));
            vec4 nextImages = texture2D(uNextTexture, vec2(uv.x, uv.y + (1.0 - uChangeTransition)));
            gl_FragColor = mix(currentImages, nextImages, uChangeTransition);
          }
        `
      });

      this.mesh = new THREE.Mesh(this.geometry, this.material);
      this.scene.add(this.mesh);

      this.tl = gsap.timeline({ repeat: -1 });
      this.tl.to(this.material.uniforms.uChangeTransition, {
        value: 1, ease: "power4.out", delay: 0.6, duration: 3,
      }).to(this.material.uniforms.uChangeTransition, {
        value: 0, ease: "power4.out", delay: 0.6, duration: 3,
      });

      this.isRendering = true;
      this.animate();
    }

    dispose() {
      this.isRendering = false;
      if (this.tl) this.tl.kill();
      if (!this.renderer) return;
      this.renderer.dispose();
      this.renderer.domElement.remove();
      this.renderer = null;
    }

    animate() {
      if (!this.isRendering) return;
      requestAnimationFrame(() => this.animate());
      if (this.renderer && this.scene && this.camera) {
        this.renderer.render(this.scene, this.camera);
      }
    }
  }

  document.addEventListener("astro:page-load", () => {
    const el = document.querySelector(".ml-shader-noise-container");
    if (el) new MLShaderNoiseChange(el);
  });
</script>
ipt>
