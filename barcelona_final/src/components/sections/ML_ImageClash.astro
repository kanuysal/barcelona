---
// ML_ImageClash.astro - 1:1 Original Implementation using PIXI.js
const { image = "/assets/images/abiye.webp" } = Astro.props;
---
<div class="ml-image-clash-container" data-image={image}>
  <div class="stage"></div>
  <div class="ml-clash-overlay">
    <h2>IMAGE CLASH</h2>
    <p>Binlerce parçacık ile interaktif görsel etkileşimi</p>
  </div>
</div>

<style>
  .ml-image-clash-container {
    position: relative;
    width: 100%;
    height: 600px;
    background: #e5e5e5;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .stage {
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Target Pixi Canvas */
  canvas {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .ml-clash-overlay {
    position: absolute;
    top: 40px;
    left: 40px;
    color: #333;
    pointer-events: none;
    z-index: 10;
  }

  .ml-clash-overlay h2 {
    font-family: 'Cinzel', serif;
    font-size: 1.5rem;
    letter-spacing: 0.3em;
    margin-bottom: 5px;
  }

  .ml-clash-overlay p {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    opacity: 0.6;
  }
</style>

<script>
  import * as PIXI from 'pixi.js';

  class Particle {
    constructor(x, y, texture, size) {
      this.x = x;
      this.y = y;
      this.sprite = new PIXI.Sprite(new PIXI.Texture(texture.baseTexture, new PIXI.Rectangle(x, y, size, size)));
      this.sprite.x = x;
      this.sprite.y = y;
      this.speedX = 0;
      this.speedY = 0;
      this.radius = 110;
      this.friction = 0.8;
      this.gravity = 0.01;
    }

    update(mouse) {
      if (!mouse) return;
      let dx = mouse.x - this.sprite.x;
      let dy = mouse.y - this.sprite.y;
      let dist = Math.sqrt(dx * dx + dy * dy);
      
      if (dist < this.radius) {
        let nx = dx / dist;
        let ny = dy / dist;
        this.sprite.x -= nx * 2;
        this.sprite.y -= ny * 2;
      }

      const ox = this.x - this.sprite.x;
      const oy = this.y - this.sprite.y;

      this.speedX += ox * this.gravity;
      this.speedY += oy * this.gravity;
      this.speedX *= this.friction;
      this.speedY *= this.friction;

      this.sprite.x += this.speedX;
      this.sprite.y += this.speedY;
    }
  }

  class MLImageClash {
    constructor(el) {
      this.container = el;
      this.stage = el.querySelector(".stage");
      this.imageUrl = el.dataset.image;
      this.particles = [];
      this.particleSize = 6;
      this.app = null;
      this.init();
    }

    async init() {
      this.app = new PIXI.Application();
      await this.app.init({
        width: 1000,
        height: 1000,
        background: { color: 0xe5e5e5, alpha: 1 },
        resolution: window.devicePixelRatio || 1,
        preference: 'webgl'
      });
      
      this.stage.appendChild(this.app.canvas);

      const observer = new IntersectionObserver(async (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            if (this.particles.length === 0) await this.setupParticles();
            this.app.ticker.start();
          } else {
            this.app.ticker.stop();
          }
        }
      }, { threshold: 0.1 });
      observer.observe(this.container);
    }

    async setupParticles() {
      try {
        const texture = await PIXI.Assets.load(this.imageUrl);
        const loopCount = Math.floor(1000 / this.particleSize);
        const container = new PIXI.Container();
        this.app.stage.addChild(container);

        for (let i = 0; i < loopCount; i++) {
          for (let j = 0; j < loopCount; j++) {
            if (i * this.particleSize < texture.width && j * this.particleSize < texture.height) {
              const p = new Particle(i * this.particleSize, j * this.particleSize, texture, this.particleSize);
              this.particles.push(p);
              container.addChild(p.sprite);
            }
          }
        }

        container.x = (1000 - texture.width) / 2;
        container.y = (1000 - texture.height) / 2;

        this.app.ticker.add(() => {
          // Fix for PixiJS v8 interaction
          const mouse = this.app.renderer.events.pointer.global;
          const adjMouse = {
            x: mouse.x - container.x,
            y: mouse.y - container.y
          };
          this.particles.forEach(p => p.update(adjMouse));
        });
      } catch (e) {
        console.error("PIXI Load Error", e);
      }
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    const el = document.querySelector(".ml-image-clash-container");
    if (el) new MLImageClash(el);
  });
</script>
