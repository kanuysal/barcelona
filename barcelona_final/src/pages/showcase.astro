---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Koleksiyon | Mina Lidya - Elite Couture"
  description="Mina Lidya Elite Couture Koleksiyonu - En özel tasarımlarımızla zerafeti keşfedin."
  swupRoute="showcase"
  showFooter={false}
>
  <main class="main" data-lenis="main">
    <div class="showcase">
      <div class="showcase-filter"></div>
      <div id="showcase"></div>
      <section class="showcase-main">
        <ul class="showcase-main__ul">
          <a href="https://minalidya.wedding" class="showcase-main__li" target="_blank" rel="noopener">
            <div class="showcase-main__image">
              <picture>
                <source srcset="/assets/images/abiye.webp" media="(max-width:767px)">
                <img src="/assets/images/abiye.webp" alt="Abiye Koleksiyonu" loading="eager" fetchpriority="high">
              </picture>
            </div>
          </a>
          <a href="https://minalidya.com" class="showcase-main__li" target="_blank" rel="noopener">
            <div class="showcase-main__image">
              <picture>
                <source srcset="/assets/images/after.webp" media="(max-width:767px)">
                <img src="/assets/images/after.webp" alt="After Party" loading="eager">
              </picture>
            </div>
          </a>
          <a href="https://minalidya.es" class="showcase-main__li" target="_blank" rel="noopener">
            <div class="showcase-main__image">
              <picture>
                <source srcset="/assets/images/curvy.webp" media="(max-width:767px)">
                <img src="/assets/images/curvy.webp" alt="Büyük Beden" loading="eager">
              </picture>
            </div>
          </a>
          <a href="https://inegolgelinlik.com" class="showcase-main__li" target="_blank" rel="noopener">
            <div class="showcase-main__image">
              <picture>
                <source srcset="/assets/images/gelinlik.webp" media="(max-width:767px)">
                <img src="/assets/images/gelinlik.webp" alt="Gelinlik" loading="eager">
              </picture>
            </div>
          </a>
          <a href="https://maifest.minalidya.wedding" class="showcase-main__li" target="_blank" rel="noopener">
            <div class="showcase-main__image">
              <picture>
                <source srcset="/assets/images/kaftan.webp" media="(max-width:767px)">
                <img src="/assets/images/kaftan.webp" alt="Kaftan" loading="eager">
              </picture>
            </div>
          </a>
          <a href="https://gallery.minalidya.wedding" class="showcase-main__li" target="_blank" rel="noopener">
            <div class="showcase-main__image">
              <picture>
                <source srcset="/assets/images/kina.webp" media="(max-width:767px)">
                <img src="/assets/images/kina.webp" alt="Kına Gecesi" loading="eager">
              </picture>
            </div>
          </a>
        </ul>
      </section>

      <div class="showcase-head-cover">
        <div class="showcase-head__titles">
          <div class="showcase-head__titles-cover">
            <div class="showcase-head__titles-group">
              <p class="c-head-font"><a href="https://minalidya.wedding" target="_blank" rel="noopener">minalidya.wedding</a></p>
              <p class="c-head-font"><a href="https://minalidya.com" target="_blank" rel="noopener">minalidya.com</a></p>
              <p class="c-head-font"><a href="https://minalidya.es" target="_blank" rel="noopener">minalidya.es</a></p>
              <p class="c-head-font"><a href="https://inegolgelinlik.com" target="_blank" rel="noopener">inegolgelinlik.com</a></p>
              <p class="c-head-font"><a href="https://maifest.minalidya.wedding" target="_blank" rel="noopener">maifest.minalidya.wedding</a></p>
              <p class="c-head-font"><a href="https://gallery.minalidya.wedding" target="_blank" rel="noopener">gallery.minalidya.wedding</a></p>
            </div>
          </div>
        </div>

        <div class="showcase-head">
          <h1 class="c-en-text--md">Koleksiyon</h1>
          <div class="showcase-separate"></div>
          <div class="showcase-length c-en-text--md">
            <p><span class="current"></span></p>
            <p>/</p>
            <p>06</p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <slot />
</MainLayout>
