                <div class="p-home-grid-mode__item-image">
                  <img src="/assets/images/Veronica Elite (7).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" fetchpriority="low" />
                </div> 
              </a>
              <a href="/shop/product" class="p-home-grid-mode__item">
                <p class="p-home-grid-mode__item-num">8</p>
                <div class="p-home-grid-mode__item-image">
                  <img src="/assets/images/Veronica Elite (8).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" fetchpriority="low" />
