            <div class="p-home-grid-mode__full" data-mobile-hide>
              <img src="/assets/images/Veronica Elite (1).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" />
              <img src="/assets/images/Veronica Elite (2).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" />
              <img src="/assets/images/Veronica Elite (3).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" />
              <img src="/assets/images/Veronica Elite (4).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" />
              <img src="/assets/images/Veronica Elite (5).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" />
              <img src="/assets/images/Veronica Elite (6).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" />
              <img src="/assets/images/Veronica Elite (7).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" />
              <img src="/assets/images/Veronica Elite (8).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" />
              <img src="/assets/images/Veronica Elite (9).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" />
            </div>
            
            <div id="canvas"></div>
          </section>
          
          <div class="p-home-view">
            <button class="p-home-view__button is-current" data-grid-view>
              <span>Galeri</span>
            </button>
            <button class="p-home-view__button" data-list-view>
              <span>Slayt</span>
            </button>
            <div class="p-home-view__background"></div>
          </div>
          <p class="p-home-scroll">↓　Aşağı Kaydır</p>
        </div>
      </main>

      <!-- Ghost Component: Forces Astro Bundler to preload WebGL Javascript Logic for Barba.js Transitions -->
      <div style="display: none;" aria-hidden="true">
        <ML_ProductGalleryDistortion />
      </div>
    </div>

    <footer class="l-footer">
      <small class="l-footer__copy">&copy; 2026 Mina Lidya</small>
    </footer>

    <div id="webgl">
      <div class="transition-text-cover" aria-hidden="true">
        <p class="transition-text">Mina Lidya</p>
        <img src="/images/leaf.svg" alt="" />
      </div>
    </div>

    <script type="module" src="/assets/js/ml_shop_engine.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
    <script is:inline>
      // Barba Hooks / Dinamik DOM yükleme çözücü Desteği
      const bootAllInteractions = () => {
        if (typeof window.initProductGallery === 'function') {
          window.initProductGallery();
        }

        const btn = document.getElementById('ml-open-detail-btn');
        if (btn && !btn.hasAttribute('data-lightbox-bound')) {
           btn.setAttribute('data-lightbox-bound', 'true');
           const lightbox = document.getElementById('ml-detail-lightbox');
           const bg = document.getElementById('ml-detail-bg');
           const closeBtn = document.getElementById('ml-detail-close');
           const inner = document.getElementById('ml-detail-inner');

           if(lightbox) {
             btn.addEventListener('click', () => {
                lightbox.classList.add('is-active');
                gsap.timeline()
                  .to(bg, { opacity: 1, duration: 0.4, ease: "power2.out" })
                  .to(inner, { opacity: 1, y: 0, duration: 0.6, ease: "expo.out" }, "-=0.2")
                  .to(closeBtn, { opacity: 1, duration: 0.3 }, "-=0.4");
             });

             const closeLB = () => {
                 gsap.timeline({
                   onComplete: () => lightbox.classList.remove('is-active')
                 })
                 .to(inner, { opacity: 0, y: 20, duration: 0.4, ease: "expo.in" })
                 .to(closeBtn, { opacity: 0, duration: 0.2 }, "-=0.2")
                 .to(bg, { opacity: 0, duration: 0.3, ease: "power2.in" }, "-=0.2");
             };

             closeBtn.addEventListener('click', closeLB);
             bg.addEventListener('click', closeLB);
           }
        }
      };

      document.addEventListener('DOMContentLoaded', bootAllInteractions);
      
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.addedNodes.length) {
            mutation.addedNodes.forEach((node) => {
              if (node.nodeType === 1 && (node.classList.contains('p-single') || node.querySelector('.p-single'))) {
                setTimeout(bootAllInteractions, 50); // DOM render süresini bekler
              }
            });
          }
        });
      });
      observer.observe(document.body, { childList: true, subtree: true });
    </script>
  </body>
</html>
