              <a href="/shop/product" class="p-home-grid-mode__item">
                <p class="p-home-grid-mode__item-num">3</p>
                <div class="p-home-grid-mode__item-image">
                  <img src="/assets/images/Veronica Elite (3).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" fetchpriority="high" />
                </div> 
              </a>
              <a href="/shop/product" class="p-home-grid-mode__item">
                <p class="p-home-grid-mode__item-num">4</p>
                <div class="p-home-grid-mode__item-image">
                  <img src="/assets/images/Veronica Elite (4).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" fetchpriority="high" />
                </div> 
              </a>
              <a href="/shop/product" class="p-home-grid-mode__item">
                <p class="p-home-grid-mode__item-num">5</p>
                <div class="p-home-grid-mode__item-image">
                  <img src="/assets/images/Veronica Elite (5).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" fetchpriority="low" />
                </div> 
              </a>
              <a href="/shop/product" class="p-home-grid-mode__item">
                <p class="p-home-grid-mode__item-num">6</p>
                <div class="p-home-grid-mode__item-image">
                  <img src="/assets/images/Veronica Elite (6).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" fetchpriority="low" />
                </div> 
