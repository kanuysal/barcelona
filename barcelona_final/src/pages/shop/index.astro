                <img src="/assets/images/Veronica Elite (3).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" />
                <img src="/assets/images/Veronica Elite (4).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" />
                <img src="/assets/images/Veronica Elite (5).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" />
                <img src="/assets/images/Veronica Elite (6).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" />
                <img src="/assets/images/Veronica Elite (7).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" />
                <img src="/assets/images/Veronica Elite (8).webp" alt="photo thumbnail" width="200" height="300" loading="lazy" decoding="async" />
