        <div class="c-loading__icon"><img src="/images/leaf.svg" alt="" /></div>
        <p class="c-loading__text">
          <span data-load-first>M</span> <span data-load-first>i</span>
          <span data-load-first>n</span> <span data-load-first>a</span>
          <span class="u-space"></span>
          <span data-load-first>L</span> <span data-load-first>i</span>
